#!/usr/bin/env bash
#
# Run integration tests for flaky scripts (intermittent failures driven by
# upstream issues like broken submodules or Gerrit/Phabricator outages).
# Separated from ./test_integration so that suite can stay fast and reliable.
# Failures here may reflect upstream issues rather than regressions in this
# repo. Long-running but deterministic scripts live in ./test_integration_slow.
# Entries are added based on observed instability, not naming — many scripts
# whose names contain "_gated" are reliable and live in ./test_integration.
# Each entry is annotated with its approximate runtime in minutes.
# WARNING: This will take a long time to run.
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./test_integration_flaky
#        VERBOSE=1 ./test_integration_flaky
#

# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking
. "$(dirname "$0")"/lib/run_test    # provides run_test function and test_counter

# --- Known-flaky entries ---
run_test ./run_selenium_tests_gated  # ?m: test run_selenium_tests_gated (installs all gated, runs all selenium tests; also tests install_all_gated) — runtime not recently measured

# Print pass/fail summary and exit with error if any script failed
print_results

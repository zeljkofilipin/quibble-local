#!/usr/bin/env bash
#
# Run deep_clean, then run all tests. Slower but starts from a clean state.
# WARNING: This will take a very long time to run.
#
# Usage: ./deep_test
#        ./deep_test --verbose
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/verbose # parse --verbose flag, set QUIBBLE_VERBOSE

# Remove everything quibble-local created
"$(dirname "$0")"/deep_clean
# Run all tests
"$(dirname "$0")"/test

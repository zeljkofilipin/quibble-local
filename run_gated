#!/usr/bin/env bash
#
# Install all gated extensions and skins into a single MediaWiki, then run all Selenium tests.
# Unlike run_all (which does fresh_install per component), this installs everything together.
# For each gated component: install it (stacking on the same src/). Then for each component
# that has Selenium tests: run them.
# WARNING: This will take a long time to run (50+ components).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./run_gated
#        VERBOSE=1 ./run_gated
#

# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking

# --- Core ---
if [ -n "$verbose" ]; then
  printf "\n########################################\n"
  printf "# Core %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
  printf "########################################\n"
else
  printf "core " # print component name, dots will follow on same line
fi
if ! run_step core ./fresh_install; then # install core; abort if this fails
  printf " %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
  print_results
  exit 1
fi
printf " %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')" # print UTC timestamp after core

# --- Install all gated repositories ---
components=() # array of successfully installed components
# IFS= preserves whitespace in component names; -r prevents backslash interpretation.
# <&3 reads from file descriptor 3 instead of stdin, because docker's -it flag needs stdin.
# 3< <(...) is process substitution: runs ./gated and connects its output to fd 3.
while IFS= read -r component <&3; do
  if [ -n "$verbose" ]; then
    printf "\n########################################\n"
    printf "# Install %s %s\n" "$component" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
    printf "########################################\n"
  else
    printf "%s " "$component" # print component name, dots will follow on same line
  fi
  if run_step "$component" ./install "$component"; then
    components+=("$component") # track successfully installed components
  fi
  printf " %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')" # print UTC timestamp after component
done 3< <("$(dirname "$0")"/gated)

# --- Run Selenium tests for all installed components ---
# Core first
if [ -n "$verbose" ]; then
  printf "\n########################################\n"
  printf "# Selenium: core %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
  printf "########################################\n"
else
  printf "core(selenium) " # print component name, dots will follow on same line
fi
if ./selenium_tests_exist; then # check if core has Selenium tests
  run_step core ./run_selenium_tests
fi
# Record core result
case "$failed" in
  *"core"*) ;; # already recorded as failed
  *) passed="$passed
  core" ;; # append core on a new indented line
esac
printf " %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"

# Then each gated component
for component in "${components[@]}"; do
  if [ -n "$verbose" ]; then
    printf "\n########################################\n"
    printf "# Selenium: %s %s\n" "$component" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
    printf "########################################\n"
  else
    printf "%s(selenium) " "$component" # print component name, dots will follow on same line
  fi
  if ./selenium_tests_exist "$component"; then # check if this component has Selenium tests
    run_step "$component" ./run_selenium_tests "$component"
  fi
  # Record as passed if not already in failed list
  case "$failed" in
    *"$component"*) ;; # already recorded as failed
    *) passed="$passed
  $component" ;; # append component on a new indented line
  esac
  printf " %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
done

# Print pass/fail summary and exit with error if any component failed
print_results

#!/usr/bin/env bash
#
# Run integration tests that are too slow for the fast suite (./test_integration).
# Includes network-heavy setup, full test suites, exhaustive algorithms, and
# gated repository tests.
# Each entry is annotated with its approximate runtime in minutes.
# WARNING: This will take a long time to run.
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./test_integration_slow
#        VERBOSE=1 ./test_integration_slow
#

# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking
. "$(dirname "$0")"/lib/run_test    # provides run_test function and test_counter

# --- Core PHPUnit (slow: full core test suite) ---
# fresh_install is fast but required: run_php_unit_tests assumes src/ already has
# MediaWiki installed. The later find_dependencies_minimal_greedy* entries set up src/ themselves
# (via lib/minimal_setup), so they don't need this.
run_test ./fresh_install               # 1m: install core so run_php_unit_tests has something to test
run_test ./run_php_unit_tests          # 13m: test running all core PHPUnit tests
run_test ./run_php_unit_tests --filter testValidSpecialPageAliases  # 1m: test filtering core PHPUnit tests

# --- Finding minimum dependencies (slow: exhaustive algorithms) ---
run_test ./find_dependencies_minimal_bottom_up extensions/Echo  # 4m: test bottom-up exhaustive (fast for Echo: 0 deps needed)
run_test env PARALLEL=2 ./find_dependencies_minimal_bottom_up extensions/Echo  # 7m: test bottom-up with parallel mode
run_test ./find_dependencies_minimal_greedy extensions/CommunityConfiguration  # 8m: test finding minimum dependencies (greedy algorithm)
run_test ./dependencies_minimal_thorough extensions/Echo  # 21m: test greedy + exhaustive verification
run_test env PARALLEL=2 ./dependencies_minimal_thorough extensions/Echo  # 21m: test thorough with parallel mode
run_test ./find_dependencies_minimal_gated extensions/Echo  # 20m: test finding minimum dependencies for gated (single component)
run_test env PARALLEL=2 ./find_dependencies_minimal_gated extensions/Echo  # 22m: test find_dependencies_minimal_gated with parallel mode

# --- All gated repositories (moved from test_integration) ---
run_test ./prepare_gated               # 4m: test cloning bare repos for all gated repos
run_test ./install_each_gated extensions/Echo  # ~3m: test install_each_gated with a single extension
run_test env FAST=1 ./install_each_gated extensions/Echo  # ~3m: test install_each_gated with fast mode
run_test env PARALLEL=2 ./install_each_gated extensions/Echo  # ~3m: test install_each_gated with parallel mode
run_test env PARALLEL=2 FAST=1 ./install_each_gated extensions/Echo  # ~3m: test install_each_gated with parallel + fast mode
run_test ./run_selenium_tests_all_gated extensions/Echo     # 5m: test run_selenium_tests_all_gated with a single extension
run_test env FAST=1 ./run_selenium_tests_all_gated extensions/Echo  # 4m: test run_selenium_tests_all_gated with fast mode
run_test env PARALLEL=2 ./run_selenium_tests_all_gated extensions/Echo  # 4m: test run_selenium_tests_all_gated with parallel mode
run_test env PARALLEL=2 FAST=1 ./run_selenium_tests_all_gated extensions/Echo  # 4m: test run_selenium_tests_all_gated with parallel + fast mode
run_test ./run_selenium_tests_required_gated extensions/Echo  # 3m: test run_selenium_tests_required_gated with a single extension
run_test env FAST=1 ./run_selenium_tests_required_gated extensions/Echo  # 3m: test run_selenium_tests_required_gated with fast mode
run_test env PARALLEL=2 ./run_selenium_tests_required_gated extensions/Echo  # 3m: test run_selenium_tests_required_gated with parallel mode
run_test env PARALLEL=2 FAST=1 ./run_selenium_tests_required_gated extensions/Echo  # 3m: test run_selenium_tests_required_gated with parallel + fast mode
run_test ./run_selenium_tests_gated  # 73m: test run_selenium_tests_gated (installs all gated, runs all selenium tests; also tests install_all_gated)

# Print pass/fail summary and exit with error if any script failed
print_results

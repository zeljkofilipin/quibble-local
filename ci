#!/usr/bin/env bash
#
# Run the same checks that GitLab CI runs, using Docker.
# Runs shellcheck (lint) and bats (unit tests) in the same images as CI.
# Does not require ShellCheck or Bats to be installed locally.
# Usage: ./ci
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/debug_info # print debug info, check prerequisites, show verbose hint

# --- ShellCheck job (matches .gitlab-ci.yml shellcheck job) ---
# --rm: remove container after it exits
# -v: mount repo read-only into /mnt
# sh -c: install bash (not included in Alpine), then run ./lint
echo "Running shellcheck..."
docker run --rm -v "$PWD:/mnt:ro" koalaman/shellcheck-alpine:stable sh -c "apk add --no-cache bash >/dev/null 2>&1 && cd /mnt && ./lint"
echo "shellcheck passed"
echo

# --- Bats job (matches .gitlab-ci.yml bats job) ---
# --rm: remove container after it exits
# -v: mount repo read-only into /mnt
# sh -c: install bash and git (needed by lib/debug_info), then run bats
echo "Running bats..."
docker run --rm -v "$PWD:/mnt:ro" --entrypoint sh bats/bats:latest -c "apk add --no-cache bash git >/dev/null 2>&1 && cd /mnt && bats test/"
echo "bats passed"

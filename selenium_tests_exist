#!/usr/bin/env bash
#
# Check if a component has Selenium tests.
# Exits 0 if selenium-test script exists in package.json, 1 otherwise.
# Clones the bare repo from Gerrit if needed, then clones from ref/ to src/.
# No Docker or fresh_install required.
#
# Usage: ./selenium_tests_exist
#        ./selenium_tests_exist extensions/Echo
#        ./selenium_tests_exist skins/MinervaNeue
#        ./selenium_tests_exist skins/Vector
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Determine the Gerrit repo, bare repo path, and clone destination
if [ $# -gt 0 ]; then
  component="$1"                                # e.g. "extensions/Echo"
  repo="mediawiki/${component}"                  # e.g. "mediawiki/extensions/Echo"
  bare_repo="ref/mediawiki/${component}.git"     # e.g. ref/mediawiki/extensions/Echo.git
  dest="src/${component}"                        # e.g. src/extensions/Echo
  package_json="src/${component}/package.json"   # e.g. src/extensions/Echo/package.json
else
  repo="mediawiki/core"                          # core Gerrit repo
  bare_repo="ref/mediawiki/core.git"             # core bare repo
  dest="src"                                     # clone core to src/
  package_json="src/package.json"                # core
fi

# Clone from bare repo to src/ if the directory doesn't exist yet
if [ ! -d "$dest" ]; then
  # Clone or fetch bare repo (--quiet: this is a data script, suppress progress output)
  . "$(dirname "$0")"/lib/clone_or_fetch
  clone_or_fetch --quiet "$repo"
  mkdir -p "$(dirname "$dest")" # create parent directories (no-op for core)
  git clone --quiet "$bare_repo" "$dest" # clone from local bare repo (no network needed)
fi

# Check if package.json exists
if [ ! -f "$package_json" ]; then
  exit 1 # no package.json means no tests
fi

# Check if package.json contains a "selenium-test" script
# -q: quiet mode, don't print matches, just set exit code (0=found, 1=not found)
grep -q '"selenium-test"' "$package_json"

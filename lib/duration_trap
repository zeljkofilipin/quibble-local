# shellcheck shell=bash
# Set EXIT trap to print script duration and/or UTC timestamp when it exits.
# Sources lib/format_duration and lib/utc_timestamp for the formatting helpers.
# Only activates when stdout is a terminal (prevents corrupting piped output),
# or when _QUIBBLE_FORCE_TERMINAL=1 is set (used by generate_example to capture
# the terminal-style duration line into examples/*.txt).
# The duration is gated on TIME_ELAPSED, the UTC timestamp on TIME_UTC (see
# lib/format_duration and lib/utc_timestamp). With both unset the trap fires
# silently. With both set the duration and UTC stamp share one line, separated
# by a space (matches install_each_gated / find_dependencies_minimal_thorough).
# lib/silent_output overrides this trap with its own handler.
# Must be sourced, not run directly.

# Source the formatting helpers
. "$(dirname "$0")"/lib/format_duration # provides _quibble_format_duration
. "$(dirname "$0")"/lib/utc_timestamp   # provides utc_timestamp (gated on TIME_UTC)

# Set EXIT trap for duration display (only when outputting to a terminal,
# or when forced via _QUIBBLE_FORCE_TERMINAL=1 — see header comment).
if [ -t 1 ] || [ -n "${_QUIBBLE_FORCE_TERMINAL:-}" ]; then
  # Demote FORCE_TERMINAL from exported to shell-local so child processes inherit the real
  # TTY status. Idempotent across debug_info / silent_output.
  export -n _QUIBBLE_FORCE_TERMINAL 2>/dev/null || :
  _quibble_duration_exit() {
    local exit_code=$?                # capture exit code before any command changes it
    { set +x; } 2>/dev/null            # disable trace output silently (may be active in verbose mode)
    # Build the two halves independently so each is gated by its own env var. Both helpers
    # return empty when their gate is off, so unset gates collapse cleanly to no output —
    # no bare "()" line, no stray UTC line, no trailing whitespace when only one is set.
    local d="" u=""
    [ -n "${TIME_ELAPSED:-}" ] && d="($(_quibble_format_duration "$SECONDS"))" # "(2m 33s)"
    [ -n "${TIME_UTC:-}" ] && u="$(utc_timestamp)"                              # "2026-05-24 02:16:33 UTC"
    if [ -n "$d" ] && [ -n "$u" ]; then
      printf "%s %s\n" "$d" "$u"      # both set: combine on one line, space-separated
    elif [ -n "$d" ]; then
      printf "%s\n" "$d"              # TIME_ELAPSED only (legacy behavior)
    elif [ -n "$u" ]; then
      printf "%s\n" "$u"              # TIME_UTC only
    fi                                  # neither set: emit nothing
    return "$exit_code"               # preserve the original exit code
  }
  trap _quibble_duration_exit EXIT    # run handler when script exits
fi

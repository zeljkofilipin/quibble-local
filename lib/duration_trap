# shellcheck shell=bash
# Set EXIT trap to print script duration when it exits.
# Sources lib/format_duration for the formatting function.
# Only activates when stdout is a terminal (prevents corrupting piped output).
# lib/silent_output overrides this trap with its own handler that also includes duration.
# Must be sourced, not run directly.

# Source the formatting function
. "$(dirname "$0")"/lib/format_duration # provides _quibble_format_duration

# Set EXIT trap for duration display (only when outputting to a terminal)
if [ -t 1 ]; then
  _quibble_duration_exit() {
    local exit_code=$?                # capture exit code before any command changes it
    { set +x; } 2>/dev/null          # disable trace output silently (may be active in verbose mode)
    printf "(%s)\n" "$(_quibble_format_duration "$SECONDS")" # print total elapsed time
    return "$exit_code"               # preserve the original exit code
  }
  trap _quibble_duration_exit EXIT    # run handler when script exits
fi

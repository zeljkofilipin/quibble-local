# shellcheck shell=bash
# Run a Quibble test command in a Docker container.
# Skips zuul clone and dependency installation (assumes ./fresh_install or ./install was run).
# Must be sourced, not run directly. Expects lib/setup and lib/parse_component_args
# to be sourced first (provides QUIBBLE_DOCKER_FLAGS, QUIBBLE_VOLUMES, QUIBBLE_IMAGE, zuul_project).
#
# Usage: run_quibble_test QUIBBLE_ARGS...
#   QUIBBLE_ARGS: arguments to pass to Quibble (e.g. --run selenium, --command "...")
# shellcheck disable=SC2154 # variables are set by lib/setup and lib/parse_component_args

run_quibble_test() {
  # "${QUIBBLE_DOCKER_FLAGS[@]}": -it in verbose mode, -i in silent mode (set by lib/setup)
  # --rm: remove container on exit
  # --entrypoint=quibble-with-supervisord: use Quibble's supervisord entrypoint
  # "${QUIBBLE_VOLUMES[@]}": mount shared volumes (cache, log, ref, src)
  # -e CI=true: tell Quibble this is a CI run
  # ${zuul_project[@]+"${zuul_project[@]}"}: bash 3.2 workaround to expand array
  #   only if non-empty (empty array with set -u would cause "unbound variable" error)
  # --skip-zuul: don't clone repos (already in src/)
  # --skip-deps: don't install dependencies (already installed)
  docker run "${QUIBBLE_DOCKER_FLAGS[@]}" --rm \
    --entrypoint=quibble-with-supervisord \
    "${QUIBBLE_VOLUMES[@]}" \
    -e CI=true \
    ${zuul_project[@]+"${zuul_project[@]}"} \
    "$QUIBBLE_IMAGE" \
    --skip-zuul \
    --skip-deps \
    "$@"
}

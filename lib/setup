# shellcheck shell=bash
# Shared setup sourced by scripts that run Docker commands.
# Sources lib/debug_info for debug output and basic prerequisites, checks Docker
# prerequisites, exports QUIBBLE_IMAGE and QUIBBLE_VOLUMES, sets a custom debug prompt,
# and enables trace output (set -x) in verbose mode.
# Not sourced by utility scripts (help, lint, test, etc.) where trace output would be noise.

# Print debug info and check basic prerequisites (git)
# $0 is the top-level script (e.g. ./fresh_install), so dirname gives the project root
_QUIBBLE_LOG="log/${0##*/}.log" # tell lib/debug_info where silent mode logs are saved (e.g. log/fresh_install.log)
. "$(dirname "$0")"/lib/debug_info

# --- Docker prerequisite checks ---
# All scripts that source lib/setup run Docker commands, so docker must be available.
# Set _QUIBBLE_NO_DOCKER_CHECK=1 to skip (used in tests to avoid requiring Docker).
if [ -z "${_QUIBBLE_NO_DOCKER_CHECK:-}" ]; then
  if ! command -v docker >/dev/null; then # check if docker is installed
    echo "Error: docker is not installed. See https://www.docker.com/" >&2 # >&2 prints to stderr
    exit 1
  fi
  if ! docker info >/dev/null 2>&1; then # check if Docker daemon is running (suppress verbose output)
    echo "Error: Docker is not running. Start Docker and try again." >&2
    exit 1
  fi
fi

# --- Shared variables ---
export QUIBBLE_IMAGE="docker-registry.wikimedia.org/releng/quibble-bullseye-php83:latest" # Docker image for Quibble
QUIBBLE_DIR="$(pwd)" # project root, captured before set -x to avoid noisy pwd trace
QUIBBLE_SRC="${QUIBBLE_SRC:-src}" # source directory, override for parallel workers (e.g. src_worker_1)
# Common Docker volume mounts for Quibble commands (cache, log, ref, src)
# shellcheck disable=SC2034 # used by scripts that source this file
QUIBBLE_VOLUMES=(
  -v "$QUIBBLE_DIR"/cache:/cache           # composer/npm cache
  -v "$QUIBBLE_DIR"/log:/workspace/log     # Quibble logs
  -v "$QUIBBLE_DIR"/ref:/srv/git:ro        # bare git repos as references
  -v "$QUIBBLE_DIR"/"$QUIBBLE_SRC":/workspace/src     # MediaWiki source code (uses QUIBBLE_SRC for parallel workers)
)

# --- Port mapping ---
# Expose MediaWiki port for interactive use. Skip in parallel mode to avoid port conflicts.
# Set QUIBBLE_EXPOSE_PORT=0 to disable (parallel workers don't need host port access).
# shellcheck disable=SC2034 # used by scripts that source this file
if [ "${QUIBBLE_EXPOSE_PORT:-1}" = "1" ]; then
  QUIBBLE_PORT_FLAGS=(-p 9413:9413) # map container port to host
else
  QUIBBLE_PORT_FLAGS=()             # no port mapping (parallel/automated mode)
fi

# --- Docker interactive flags ---
# In verbose mode (or when run directly), use -it for interactive terminal + TTY.
# In silent mode, drop -t to avoid TTY control characters in log files.
# In background mode (parallel workers), drop both -i and -t (no stdin attached).
# shellcheck disable=SC2034 # used by scripts that source this file
if [ "${QUIBBLE_BACKGROUND:-}" = "1" ]; then
  QUIBBLE_DOCKER_FLAGS=()    # no interactive flags (background worker, no stdin)
elif [ "${VERBOSE:-}" = "1" ]; then
  QUIBBLE_DOCKER_FLAGS=(-it) # interactive + TTY for terminal use
else
  QUIBBLE_DOCKER_FLAGS=(-i)  # interactive only (no TTY = clean log output)
fi

# --- Trace output (verbose mode only) ---
# In silent mode, skip set -x to keep output clean. Only show trace in verbose mode.
if [ "${VERBOSE:-}" = "1" ]; then
  PS4=$'\n========================================\n= ${0##*/} is running: ' # custom prompt showing script name (uses parameter expansion, not $(basename) which breaks set -e in bash 3.2)
  set -x # print each command before running it
fi

# --- Output redirection (silent mode only) ---
# Saves output to log file, prints dots per line, shows ok/FAIL on exit.
. "$(dirname "$0")"/lib/silent_output

# Display the command with delimiters, then execute it.
# The script name is derived from $0 of the calling script.
run() {
  local label
  label=$(basename "$0")
  local header
  header="$label is running this command:"
  local max_len
  max_len=$(printf '%s\n%s' "$header" "$1" | awk '{ if (length > max) max = length } END { print max }')
  local delimiter
  delimiter=$(printf '%*s' "$max_len" '' | tr ' ' '-')
  echo "$delimiter
$header
$delimiter
$1
$delimiter"
  eval "$(echo "$1" | tr '\n' ' ')"
}

# shellcheck shell=bash
# Sourced by long-running scripts to prevent the machine from suspending.
# Uses caffeinate on macOS, systemd-inhibit on Linux.
# The caller's PID ($$) is used so the inhibit ends when the caller exits.
if [ "$(uname)" = "Darwin" ]; then
  caffeinate -s -w $$ & # macOS: prevent sleep while the caller is alive
else
  systemd-inhibit --what=sleep --who="$(basename "$0")" --why="Quibble tests running" sleep infinity &
  inhibit_sleep_pid=$!                                    # save PID to kill on exit
  trap 'kill $inhibit_sleep_pid 2>/dev/null' EXIT         # clean up on script exit
fi

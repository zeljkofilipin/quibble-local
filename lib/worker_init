# shellcheck shell=bash
# Common setup for parallel worker subshells.
# Sets environment variables, redirects output to log file, and sets up core MediaWiki
# via restore (fast mode) or fresh_install.
# Must be sourced inside a worker subshell, not run directly.
# Expects these variables to be set by the caller:
#   worker_src      — isolated src directory for this worker (e.g. "src_worker_1")
#   worker_log_file — path to log file for this worker's output
#   fast            — FAST mode flag (empty string or "1")
#   result_file     — path to write "fail" if setup fails
# shellcheck disable=SC2154 # variables are set by the calling subshell

export QUIBBLE_SRC="$worker_src"       # isolated src directory for this worker
export QUIBBLE_BACKGROUND=1            # skip -i/-t Docker flags (no stdin in background)
exec > "$worker_log_file" 2>&1         # redirect all output to worker log file

# Set up core MediaWiki (restore from saved state in fast mode, or fresh_install from scratch)
if [ -n "$fast" ]; then
  if ! ./restore; then
    echo "fail" > "$result_file"
    exit 1
  fi
else
  if ! ./fresh_install; then
    echo "fail" > "$result_file"
    exit 1
  fi
fi

# shellcheck shell=bash
# Parallel exhaustive search for the minimum dependencies: test combinations across $parallel
# reusable slots via lib/run_pool, each in an isolated src_$slot/ directory (ENVIRONMENT=$slot).
# Combos are size-ordered and dispatched in order, so the lowest-index passing combination is the
# minimum; lib/run_pool's _quibble_run_pool_stop halts dispatch once a pass is found, and the
# lowest passing index across the drained in-flight slots wins.
# FAST mode: fresh_install + install once, save, then each worker restores.
# Normal mode: each worker runs fresh_install + install independently.
# Must be sourced, not run directly.
# Expects these variables/functions to be set by the caller:
#   component       — e.g. "extensions/Echo"
#   combos          — indexed array of space-separated optional dep combinations (size-ordered)
#   total           — total number of combinations
#   parallel        — number of parallel slots
#   fast            — FAST=1 flag (empty string or "1")
#   required_str    — space-separated list of required dependency names
#   required        — indexed array of required dependency names
#   fresh_or_restore — function to set up core MediaWiki (fresh_install or restore)
# On success it prints the winning combination (lib/print_found) and exits 0; otherwise it
# returns so the caller can report that no combination was found.
# shellcheck disable=SC2154 # variables are set by the sourcing script

if [ -n "$fast" ]; then
  # Fast mode: initial fresh_install + install + save (workers restore from src_save/)
  if ! fresh_or_restore; then
    printf "\nfresh_install/save failed. Cannot proceed.\n"
    exit 1
  fi
  # Ensure save directory exists for workers to restore from
  if [ ! -d "${QUIBBLE_SAVE:-src_save}" ]; then
    printf "\nError: %s/ missing after fresh_install+save. Cannot proceed.\n" "${QUIBBLE_SAVE:-src_save}"
    exit 1
  fi
fi

# Per-combo log + result files, keyed by the combo's 0-based index — combos are opaque dep-lists
# and can be empty, so the index is the safe key. Rooted at $QUIBBLE_LOG_DIR so a nested run can't
# collide with a sibling pool worker; run_pool reuses each slot id as combos finish.
_parallel_log_dir="${QUIBBLE_LOG_DIR:-log/silent}/parallel"
rm -rf "$_parallel_log_dir"   # drop stale logs/results from a prior run
mkdir -p "$_parallel_log_dir"

# Build a worker's full dependency list (required + this combination's optional deps) from the
# optional combo, reusing the canonical builder. $1: optional-dep combo. Echoes the full list.
_quibble_combo_full() {
  # local shadows keep optional_combo/full_combo from leaking (esp. the winning optional_combo
  # set in _collect_result). SC2034: shellcheck can't follow the dynamic source that reads
  # optional_combo and sets full_combo.
  # shellcheck disable=SC2034
  local optional_combo="$1" full_combo
  . "$(dirname "$0")"/lib/build_full_combo # sets full_combo from required_str + optional_combo
  printf '%s' "$full_combo"
}

# lib/run_pool hook: per-dispatch progress line showing the global combo index and full deps.
# run_pool prints progress to stderr, so match it. $1: slot  $2: optional-dep combo  $3: 0-based index.
_pool_worker_label() {
  local _full
  _full=$(_quibble_combo_full "$2")
  printf "  Slot %d: combo %d/%d: %s\n" "$1" "$(($3 + 1))" "$total" "${_full:-(none)}" >&2
}

# lib/run_pool hook: worker body (runs in a background subshell). Sets up core MediaWiki in this
# slot's isolated src_$slot (restore in FAST mode, else fresh_install, done inline here), installs
# the extension with this combination's deps, runs its Selenium tests,
# and writes pass/fail to a per-index result file. Must NOT install its own EXIT trap — run_pool
# sets one to touch its sentinel. $1: slot  $2: optional-dep combo  $3: 0-based combo index.
_run_pool_worker() {
  local _combo="$2" _idx="$3" _deps
  local _result_file="$_parallel_log_dir/combo-$_idx.result"
  export ENVIRONMENT="$1"     # lib/setup derives QUIBBLE_SRC=src_$slot (isolated per slot)
  export QUIBBLE_BACKGROUND=1 # skip Docker -i/-t flags (no stdin in a background worker)
  exec > "$_parallel_log_dir/combo-$_idx.log" 2>&1 # capture this combo's output to its per-index log
  # Set up core MediaWiki: restore from src_save (fast) or fresh_install, into this slot's src_$slot.
  if [ -n "$fast" ]; then
    if ! ./restore; then echo "fail" > "$_result_file"; return 1; fi
  else
    if ! ./fresh_install; then echo "fail" > "$_result_file"; return 1; fi
  fi
  _deps=$(_quibble_combo_full "$_combo")
  export QUIBBLE_DEPS="$_deps" # full dep list for ./install (QUIBBLE_DEPS overrides ./list_dependencies)
  if ! ./install "$component"; then echo "fail" > "$_result_file"; return 1; fi
  if ./run_selenium_tests "$component"; then
    echo "pass" > "$_result_file"
  else
    echo "fail" > "$_result_file"
  fi
}

# lib/run_pool hook: record the lowest-index passing combination and signal run_pool to stop
# dispatching. Runs in this shell (run_pool is sourced), so it updates the winner vars directly.
# Combos are size-ordered, so the lowest passing index is the minimum; track the min (not the first
# reaped — completion is out of order, and in-flight lower indices still drain and are seen here).
# $1: slot (unused)  $2: combo  $3: 0-based combo index.
_pool_reap() {
  local _idx="$3" _result=""
  [ -f "$_parallel_log_dir/combo-$_idx.result" ] && _result=$(cat "$_parallel_log_dir/combo-$_idx.result")
  if [ "$_result" = "pass" ]; then
    if [ -z "${_quibble_found:-}" ] || [ "$_idx" -lt "$_quibble_win_idx" ]; then
      _quibble_win_idx="$_idx" # lowest passing index so far (also gates the comparison above)
      optional_combo="$2"      # winning combo, consumed by lib/print_found below
      _quibble_found=1         # tell the post-run block to print the result and exit 0
      printf "\n  Combination %d/%d passed!\n" "$(($3 + 1))" "$total"
    fi
    _quibble_run_pool_stop=1   # stop launching further combos; in-flight lower indices still drain
  fi
}

items=("${combos[@]}")           # lib/run_pool processes items[] across $parallel slots
. "$(dirname "$0")"/lib/run_pool # run the pool using the hooks defined above

# If a passing combination was found, print it and exit success. Otherwise return to the caller
# (find_dependencies_minimal_*), which prints its own "no combination found" message.
if [ -n "${_quibble_found:-}" ]; then
  . "$(dirname "$0")"/lib/print_found # prints the winning combination (uses optional_combo)
  exit 0
fi

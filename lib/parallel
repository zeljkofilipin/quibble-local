# shellcheck shell=bash
# Parallel exhaustive search for the minimum dependencies: test combinations in waves of
# $parallel workers via lib/run_waves, each in an isolated src_worker_N/ directory. Combos are
# ordered by size, so the first passing combination is the minimum and the search stops there.
# FAST mode: fresh_install + install once, save, then each worker restores.
# Normal mode: each worker runs fresh_install + install independently.
# Must be sourced, not run directly.
# Expects these variables/functions to be set by the caller:
#   component       — e.g. "extensions/Echo"
#   combos          — indexed array of space-separated optional dep combinations (size-ordered)
#   total           — total number of combinations
#   parallel        — number of parallel workers
#   fast            — FAST=1 flag (empty string or "1")
#   required_str    — space-separated list of required dependency names
#   required        — indexed array of required dependency names
#   fresh_or_restore — function to set up core MediaWiki (fresh_install or restore)
# On success it prints the winning combination (lib/print_found) and exits 0; otherwise it
# returns so the caller can report that no combination was found.
# shellcheck disable=SC2154 # variables are set by the sourcing script

. "$(dirname "$0")"/lib/pluralize # provides pluralize() for grammatical counts ("1 worker"/"1 combination")

printf "\nParallel mode: %d %s\n" "$parallel" "$(pluralize "$parallel" worker)"

if [ -n "$fast" ]; then
  # Fast mode: initial fresh_install + install + save (workers restore from src_save/)
  if ! fresh_or_restore; then
    printf "\nfresh_install/save failed. Cannot proceed.\n"
    exit 1
  fi
  # Ensure save directory exists for workers to restore from
  if [ ! -d "${QUIBBLE_SAVE:-src_save}" ]; then
    printf "\nError: %s/ missing after fresh_install+save. Cannot proceed.\n" "${QUIBBLE_SAVE:-src_save}"
    exit 1
  fi
fi

# Build a worker's full dependency list (required + this combination's optional deps) from the
# optional combo, reusing the canonical builder. $1: optional-dep combo. Echoes the full list.
_quibble_combo_full() {
  # local shadows keep optional_combo/full_combo from leaking (esp. the winning optional_combo
  # set in _collect_result). SC2034: shellcheck can't follow the dynamic source that reads
  # optional_combo and sets full_combo.
  # shellcheck disable=SC2034
  local optional_combo="$1" full_combo
  . "$(dirname "$0")"/lib/build_full_combo # sets full_combo from required_str + optional_combo
  printf '%s' "$full_combo"
}

# lib/run_waves hook: per-worker progress line showing the global combo index and full deps.
# $1: worker number (1-based)  $2: optional-dep combo (the item)  $3: item index (0-based)
_worker_label() {
  local _full
  _full=$(_quibble_combo_full "$2")
  printf "  Worker %d: combo %d/%d: %s\n" "$1" "$(($3 + 1))" "$total" "${_full:-(none)}"
}

# lib/run_waves hook: worker body (runs in a background subshell). Installs the extension with
# this combination's deps and runs its Selenium tests. $1: result_file  $2: optional-dep combo
_run_worker() {
  local result_file="$1" _deps # result_file is read by lib/worker_init and written here
  _deps=$(_quibble_combo_full "$2")
  export QUIBBLE_DEPS="$_deps" # full dep list for ./install (QUIBBLE_DEPS overrides ./list_dependencies)
  # worker_src / worker_log_file are set by lib/run_waves; lib/worker_init reads them to isolate
  # this worker's src dir, redirect output to its log, and restore (fast) or fresh_install.
  . lib/worker_init
  if ! ./install "$component"; then
    echo "fail" > "$result_file"
    return 1
  fi
  if ./run_selenium_tests "$component"; then
    echo "pass" > "$result_file"
  else
    echo "fail" > "$result_file"
  fi
}

# lib/run_waves hook: record the first passing combination (lowest index wins, since combos are
# size-ordered) and signal run_waves to stop. $1: combo  $2: result  $3: worker_num  $4: item index
_collect_result() {
  if [ "$2" = "pass" ]; then
    printf "\n  Combination %d/%d passed!\n" "$(($4 + 1))" "$total"
    optional_combo="$1"       # winning combo, consumed by lib/print_found below
    _quibble_found=1          # tell the post-run_waves block to print the result and exit 0
    _quibble_run_waves_stop=1 # tell lib/run_waves to stop launching further work
  fi
}

# lib/run_waves hook: report a fully-failed wave (run_waves skips this after an early stop).
# $1: wave start index (0-based, inclusive)  $2: wave end index (exclusive)
_wave_end() {
  local _n=$(($2 - $1))
  printf "  All %d %s in this wave failed.\n" "$_n" "$(pluralize "$_n" combination)"
}

items=("${combos[@]}")            # lib/run_waves processes items[] in waves of $parallel
. "$(dirname "$0")"/lib/run_waves # run the wave loop using the hooks defined above

# If a passing combination was found, print it and exit success. Otherwise return to the caller
# (find_dependencies_minimal_*), which prints its own "no combination found" message.
if [ -n "${_quibble_found:-}" ]; then
  . "$(dirname "$0")"/lib/print_found # prints the winning combination (uses optional_combo)
  exit 0
fi

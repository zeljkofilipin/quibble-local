# shellcheck shell=bash
# Output redirection for silent mode.
# Saves all output to a log file and prints a dot per line to the terminal.
# On exit, prints "ok" or "FAIL" with the log file path; the elapsed-time
# portion appears only when TIME_ELAPSED=1 (see lib/format_duration).
# Must be sourced, not run directly. Only activates when:
#   - Not in verbose mode (VERBOSE is unset or empty)
#   - Not already managed (_QUIBBLE_OUTPUT_MANAGED is unset)
#   - stdout is a terminal ([ -t 1 ]) OR _QUIBBLE_FORCE_TERMINAL=1 is set
#     (the latter lets generate_example capture the silent-mode UX into examples/)

# shellcheck disable=SC2034 # _quibble_log used inside trap function
if [ -z "${VERBOSE:-}" ] && [ -z "${_QUIBBLE_OUTPUT_MANAGED:-}" ] && { [ -t 1 ] || [ -n "${_QUIBBLE_FORCE_TERMINAL:-}" ]; }; then
  # Demote FORCE_TERMINAL from exported to shell-local so child processes (docker, child
  # scripts) inherit the real TTY status. Idempotent across debug_info / duration_trap.
  export -n _QUIBBLE_FORCE_TERMINAL 2>/dev/null || :
  mkdir -p log                       # ensure log directory exists
  _quibble_log="log/${0##*/}.log"    # log file named after the script (e.g. log/fresh_install.log)
  printf "%s " "${0##*/}"            # show script name on terminal (dots will follow on same line)
  exec 3>&1 4>&2                     # save terminal stdout/stderr to fd 3/4
  # Redirect output: save to log file and print a dot per line to terminal.
  # >(...) is process substitution: creates a subshell connected via pipe.
  # tee writes to both the log file and its stdout (the pipe to while).
  # while loop reads each line and prints a dot to fd 3 (the saved terminal).
  exec > >(tee "$_quibble_log" | while IFS= read -r _; do printf "." >&3; done) 2>&1
  # On exit: close pipe (sends EOF to tee), wait for dots to finish, print result
  _quibble_exit_handler() {
    _quibble_exit_code=$?            # capture script's exit code before any command changes it
    exec 1>&3 2>&4                   # restore terminal stdout/stderr (EOF to tee via pipe close)
    wait 2>/dev/null || true         # wait for tee/dot background process to finish
    if [ "$_quibble_exit_code" -eq 0 ]; then
      # _quibble_format_duration_padded returns " (Ns)" when TIME_ELAPSED=1, empty otherwise.
      printf " ok%s\n" "$(_quibble_format_duration_padded "$SECONDS")"
    else
      printf " FAIL%s (see %s)\n" "$(_quibble_format_duration_padded "$SECONDS")" "$_quibble_log" >&2
    fi
    return "$_quibble_exit_code"     # preserve the original exit code
  }
  trap _quibble_exit_handler EXIT    # run handler when script exits (success or failure)
fi

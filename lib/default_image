# shellcheck shell=bash
# Single source of truth for the default Quibble Docker image.
#
# Sourced by lib/setup to seed QUIBBLE_IMAGE for the user-facing scripts.
# Override at runtime by exporting QUIBBLE_IMAGE.
#
# To move to a newer image (e.g. a new Debian base when MediaWiki raises its
# minimum MariaDB version), edit ONLY the line below; both consumers pick it up.
# Must be sourced, not run directly.

# shellcheck disable=SC2034 # QUIBBLE_DEFAULT_IMAGE is consumed by the scripts that source this file
QUIBBLE_DEFAULT_IMAGE="docker-registry.wikimedia.org/releng/quibble-bookworm-php83:latest"

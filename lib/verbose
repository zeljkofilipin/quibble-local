# shellcheck shell=bash
# Parse --verbose flag and set QUIBBLE_VERBOSE environment variable.
# Silent mode (no --verbose) is the default: suppresses trace output and debug info.
# Verbose mode (--verbose): shows trace output (set -x) and debug info.
# If QUIBBLE_VERBOSE is already exported by a parent script (e.g. test, run_all),
# that value is kept and arguments are not parsed.
# Removes --verbose from the argument list so callers see only their own arguments.
# Sourced by all scripts as the first lib/ include.

# Only parse --verbose from args if QUIBBLE_VERBOSE was not already set by a parent script.
# ${QUIBBLE_VERBOSE+x} expands to "x" if QUIBBLE_VERBOSE exists (even if empty), nothing if unset.
if [ -z "${QUIBBLE_VERBOSE+x}" ]; then
  QUIBBLE_VERBOSE="" # default: silent mode (empty string = silent)
  _quibble_args=()   # temporary array to collect non-verbose arguments
  for _quibble_arg in "$@"; do # loop over all script arguments
    if [ "$_quibble_arg" = "--verbose" ]; then # check for the --verbose flag
      QUIBBLE_VERBOSE=1 # enable verbose mode
    else
      _quibble_args+=("$_quibble_arg") # keep non-verbose arguments
    fi
  done
  # Replace the script's arguments with the filtered list (--verbose removed).
  # ${arr[@]+"${arr[@]}"} is a bash 3.2 workaround: expands the array only if non-empty
  # to avoid "unbound variable" error with set -u on bash 3.2.
  set -- ${_quibble_args[@]+"${_quibble_args[@]}"}
  unset _quibble_args _quibble_arg # clean up temporary variables
fi
export QUIBBLE_VERBOSE # make available to child processes

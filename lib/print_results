# shellcheck shell=bash
# Prints pass/fail summary and exits with error if any failures.
# Expects $passed and $failed variables to be set by the caller.
# Sourced by scripts that track test/step results (run_all, run_required, test_integration).
print_results() {
  # print results section header
  printf "\n========================================\n"
  printf "= Results\n"
  printf "========================================\n"

  # -n tests if the string is non-empty
  if [ -n "$passed" ]; then # if any items passed
    printf "PASSED:%s\n" "$passed" # print list of passed items
  fi

  if [ -n "$failed" ]; then # if any items failed
    printf "FAILED:%s\n" "$failed" # print list of failed items
    if [ -z "${VERBOSE:-}" ]; then # if in silent mode
      printf "\nLogs: log/silent/\n" # point to log directory for debugging
    fi
    exit 1 # exit with error if anything failed
  fi

  printf "\nAll passed.\n" # only reached if nothing failed
}

# shellcheck shell=bash
# Format elapsed seconds as human-readable duration string.
# Provides _quibble_format_duration and _quibble_format_duration_padded functions.
# Gated on the TIME_ELAPSED environment variable: off by default (no output);
# set TIME_ELAPSED=1 to enable. This matches the project's VERBOSE=1 / TIME_UTC=1 opt-in convention.
# Sourced by lib/duration_trap and lib/batch_setup.

# Format seconds as human-readable duration string.
# Omits zero-value days, hours, and minutes. Always shows seconds.
# Usage: _quibble_format_duration SECONDS
# Example: _quibble_format_duration 3661  →  "1h 1m 1s" (when TIME_ELAPSED=1)
#          _quibble_format_duration 3661  →  ""         (when TIME_ELAPSED unset)
_quibble_format_duration() {
  [ -n "${TIME_ELAPSED:-}" ] || return 0    # default off; opt in with TIME_ELAPSED=1 (any non-empty value)
  local total="$1"                          # total elapsed seconds
  local days=$((total / 86400))             # 86400 seconds per day
  local hours=$(( (total % 86400) / 3600 )) # remaining hours after days
  local minutes=$(( (total % 3600) / 60 ))  # remaining minutes after hours
  local seconds=$((total % 60))             # remaining seconds after minutes
  local result=""                            # build up the output string
  if [ "$days" -gt 0 ]; then                # include days only if non-zero
    result="${days}d "
  fi
  if [ "$hours" -gt 0 ]; then               # include hours only if non-zero
    result="${result}${hours}h "
  fi
  if [ "$minutes" -gt 0 ]; then             # include minutes only if non-zero
    result="${result}${minutes}m "
  fi
  result="${result}${seconds}s"              # always include seconds
  printf "%s" "$result"                      # print without trailing newline
}

# Return the duration wrapped in parens with a leading space, for embedding mid-line.
# Returns " (DURATION)" when TIME_ELAPSED=1, empty otherwise (delegates the gate to
# _quibble_format_duration, so callers don't need their own [ -n "$TIME_ELAPSED" ] check).
# Designed to let callers use a single printf format string that produces clean output
# in both modes, e.g.  printf "%s\n" "$(_quibble_format_duration_padded "$dur")"
#   TIME_ELAPSED=1  →  " (1m 30s)\n"
#   TIME_ELAPSED=   →  "\n"
# Usage: _quibble_format_duration_padded SECONDS
_quibble_format_duration_padded() {
  local d
  d="$(_quibble_format_duration "$1")"       # returns "" when TIME_ELAPSED is unset
  if [ -n "$d" ]; then                       # only emit the wrapper when there's content
    printf " (%s)" "$d"
  fi
  # Don't use `[ -n "$d" ] && printf ...` here — that would make this function exit
  # non-zero when $d is empty (the [ test fails), surprising callers that check $?.
}

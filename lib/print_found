# shellcheck shell=bash
# Print the "minimum dependencies found" results.
# Must be sourced, not run directly.
# Expects these variables to be set by the caller:
#   component      — e.g. "extensions/Echo"
#   required_str   — space-separated list of required dependency names
#   required       — indexed array of required dependency names
#   optional_combo — space-separated list of optional deps in the winning combination
# shellcheck disable=SC2154 # variables are set by the sourcing script

# Print header
printf "\n========================================\n"
printf "= FOUND: minimum dependencies for %s\n" "$component"
printf "========================================\n"

# Build full combo: required + optional
full_combo="" # space-separated list of all deps in the winning combination
if [ -n "$required_str" ] && [ -n "$optional_combo" ]; then
  full_combo="$required_str $optional_combo" # both required and optional
elif [ -n "$required_str" ]; then
  full_combo="$required_str" # required only
else
  full_combo="$optional_combo" # optional only (or empty)
fi

# Print results
if [ -z "$full_combo" ]; then
  printf "\nNo dependencies needed.\n"
else
  printf "\nMinimum dependencies:\n"
  if [ ${#required[@]} -gt 0 ]; then
    printf "  Required (always needed):\n"
    for dep in "${required[@]}"; do
      printf "    %s\n" "$dep"
    done
  fi
  if [ -n "$optional_combo" ]; then
    printf "  Optional (minimum needed):\n"
    # shellcheck disable=SC2086 # intentional word splitting on space-separated combo
    for dep in $optional_combo; do
      printf "    %s\n" "$dep"
    done
  else
    printf "  Optional: (none needed)\n"
  fi
fi

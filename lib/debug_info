# shellcheck shell=bash
# Outputs debug information, checks basic prerequisites, shows a verbose mode hint,
# and sets up duration tracking. Sourced by all scripts. Docker-specific prerequisite checks are in lib/setup.

# --- Prerequisite checks ---
# Check that git is installed (required by all scripts)
if ! command -v git >/dev/null; then # command -v returns 0 if the command is found
  echo "Error: git is not installed. See https://git-scm.com/" >&2 # >&2 prints to stderr
  exit 1
fi

# Print host CPU model, logical core count, and total RAM. Branches on uname for OS-specific APIs.
_quibble_print_host_resources() {
  local cpu_model cpu_count ram_bytes ram_kb ram_gb        # locals to avoid leaking into caller
  case "$(uname -s)" in                                    # branch on OS name
    Darwin)                                                # macOS uses sysctl
      cpu_model=$(sysctl -n machdep.cpu.brand_string 2>/dev/null) # e.g. "Apple M1 Max"
      cpu_count=$(sysctl -n hw.ncpu 2>/dev/null)           # logical CPU count
      ram_bytes=$(sysctl -n hw.memsize 2>/dev/null)        # total RAM in bytes
      ;;
    Linux)                                                 # Linux exposes /proc
      # First "model name" line in /proc/cpuinfo (absent on ARM where we fall back to architecture)
      cpu_model=$(awk -F: '/^model name/ {sub(/^[[:space:]]+/, "", $2); print $2; exit}' /proc/cpuinfo 2>/dev/null)
      [ -z "$cpu_model" ] && cpu_model=$(uname -m)         # fallback e.g. "aarch64" or "x86_64"
      cpu_count=$(nproc 2>/dev/null)                       # logical CPU count
      ram_kb=$(awk '/^MemTotal:/ {print $2; exit}' /proc/meminfo 2>/dev/null) # total RAM in kB
      ram_bytes=$((${ram_kb:-0} * 1024))                   # convert kB -> bytes; default 0 if unset
      ;;
  esac
  : "${cpu_model:=unknown}"                                # final fallback if lookup failed
  : "${cpu_count:=unknown}"                                # final fallback if lookup failed
  : "${ram_bytes:=0}"                                      # final fallback if lookup failed
  # Format bytes as GB with one decimal place (1024^3 = 1073741824 bytes per GB)
  ram_gb=$(awk -v b="$ram_bytes" 'BEGIN { printf "%.1f", b / 1073741824 }')
  echo "CPU: $cpu_model ($cpu_count cores)"                # e.g. "CPU: Apple M1 Max (10 cores)"
  echo "RAM: ${ram_gb} GB"                                 # e.g. "RAM: 32.0 GB"
}

# Print docker daemon resource allocation (CPUs, RAM) if the daemon is reachable.
# On macOS Docker Desktop these are the resources allocated to the VM;
# on Linux these typically match the host since docker uses the host kernel.
_quibble_print_docker_resources() {
  local resources cpus mem_bytes mem_gb                    # locals to avoid leaking into caller
  # docker info --format avoids parsing full output; suppress errors if daemon not running
  resources=$(docker info --format '{{.NCPU}} {{.MemTotal}}' 2>/dev/null)
  [ -z "$resources" ] && return                            # daemon not reachable; skip silently
  cpus=$(echo "$resources" | awk '{print $1}')             # CPU count available to docker
  mem_bytes=$(echo "$resources" | awk '{print $2}')        # RAM bytes available to docker
  # Format bytes as GB with one decimal place (1024^3 = 1073741824 bytes per GB)
  mem_gb=$(awk -v b="$mem_bytes" 'BEGIN { printf "%.1f", b / 1073741824 }')
  echo "docker CPUs: $cpus"                                # e.g. "docker CPUs: 8"
  echo "docker RAM: ${mem_gb} GB"                          # e.g. "docker RAM: 12.0 GB"
}

# --- Debug information and verbose mode hint ---
# Only print when stdout is a terminal ([ -t 1 ]). This suppresses debug output when
# a script's stdout is piped or captured (e.g. ./list_dependencies called from ./install via
# process substitution, or child scripts whose output flows through run_with_dots).
if [ -t 1 ]; then
  # In silent mode, tell the user how to get full output and where logs are saved
  if [ -z "${VERBOSE:-}" ]; then # only show hint when VERBOSE is not set
    echo "use VERBOSE=1 for full output"
    # Show log location if the caller set _QUIBBLE_LOG (only scripts with silent mode set this)
    if [ -n "${_QUIBBLE_LOG:-}" ]; then # _QUIBBLE_LOG is set by lib/setup
      echo "logs: $_QUIBBLE_LOG"
    fi
    echo                                   # blank line after hint
  fi
  echo "OS: $(uname -s) $(uname -r)"    # e.g. "Darwin 25.3.0" or "Linux 6.1.0"
  _quibble_print_host_resources         # CPU model, core count, total RAM
  echo "bash: ${BASH_VERSION}"           # e.g. "3.2.57(1)-release"
  echo "git: $(git --version)"           # e.g. "git version 2.43.0"
  # Print docker version only if docker is installed (not all scripts need docker)
  if command -v docker >/dev/null; then
    echo "docker: $(docker --version)"  # e.g. "Docker version 24.0.7"
    _quibble_print_docker_resources     # docker CPUs and RAM (skipped if daemon not running)
  fi
  echo                                   # blank line after debug info
fi

# --- Duration tracking ---
# Source duration trap to print elapsed time when the script exits.
# The EXIT trap only activates when stdout is a terminal.
# lib/silent_output overrides this trap with its own handler that includes duration.
. "$(dirname "$0")"/lib/duration_trap

# shellcheck shell=bash
# Shared setup for batch scripts (test_integration, run_selenium_tests_all_gated, run_selenium_tests_required_gated, find_dependencies_minimal_greedy, find_dependencies_minimal_bottom_up, find_dependencies_minimal_thorough, find_dependencies_minimal_gated).
# Sets up verbose/silent mode, sources helper libraries (including duration tracking), creates log directory.
# Must be sourced, not run directly.

# Check verbose mode (default is silent)
verbose="${VERBOSE:-}" # VERBOSE=1 enables verbose mode; empty string means silent

# Directory for silent-mode per-step log files. Defaults to log/silent. A parent that runs
# batch scripts concurrently overrides it per worker (e.g. generate_examples' pool workers set
# log/silent/slot-N) so concurrent workers don't clobber each other's logs or delete logs that a
# sibling is reading back (e.g. find_dependencies_minimal_gated's FOUND block). Exported so nested
# batch children (e.g. find_dependencies_minimal_greedy) write to the same directory. NOTE: this is
# the file-write location only — the user-facing "logs:" hint (_QUIBBLE_LOG below) stays the
# canonical log/silent/ so a per-worker slot path can't leak into captured examples/.
QUIBBLE_LOG_DIR="${QUIBBLE_LOG_DIR:-log/silent}"
export QUIBBLE_LOG_DIR

. "$(dirname "$0")"/lib/inhibit_sleep  # prevent the machine from suspending
. "$(dirname "$0")"/lib/print_results  # provides print_results function
. "$(dirname "$0")"/lib/utc_timestamp  # provides utc_timestamp function
. "$(dirname "$0")"/lib/print_header   # provides print_header function
. "$(dirname "$0")"/lib/record_passed  # provides record_passed function
. "$(dirname "$0")"/lib/heartbeat      # provides run_with_dots function
. "$(dirname "$0")"/lib/duration_trap  # provides _quibble_format_duration and sets EXIT trap for total duration

# Create and clean log directory for silent mode
if [ -z "$verbose" ]; then
  _QUIBBLE_LOG="log/silent/" # tell lib/debug_info where silent mode logs are saved (literal, NOT $QUIBBLE_LOG_DIR: debug_info prints this to stdout and generate_example captures it — a slot path here would leak into examples/)
  . "$(dirname "$0")"/lib/debug_info # check prerequisites and print debug info before output is redirected
  # Best-effort fix-up of log/ permissions before creating log/silent/. Docker mounts log/
  # as a volume and writes to it as the container user, which can leave log/ root-owned on
  # the host. `chmod 777 log` succeeds when the current user owns log/ (fast path) and is
  # a no-op when log/ is already 777. Suppress errors and don't fail here — the mkdir
  # below is the authoritative check.
  chmod 777 log 2>/dev/null || :
  mkdir -p "$QUIBBLE_LOG_DIR" 2>/dev/null || : # create log directory for captured output (errors handled below)
  # Fail loudly if log/silent could not be created. Without this check, subsequent `tee`
  # commands in run_with_dots would fail per-step with `tee: log/silent/...: No such file or
  # directory` and the script would limp along producing noise instead of useful output.
  if [ ! -d "$QUIBBLE_LOG_DIR" ]; then
    echo "Error: cannot create $QUIBBLE_LOG_DIR. log/ is likely owned by root from a previous Docker run." >&2
    echo "Fix: run ./remove_all to wipe all generated directories (uses Docker-as-root to delete root-owned files), then start fresh." >&2
    exit 1
  fi
  # Clear old logs to avoid confusion from stale results — but only at the OUTERMOST batch
  # invocation. When this script is sourced by an inner batch (e.g. find_dependencies_minimal_gated
  # invokes find_dependencies_minimal_greedy via run_step, which pipes greedy's output to
  # `tee log/silent/<component>--find_dependencies_minimal_greedy.log`), greedy's own
  # batch_setup would otherwise unlink the file tee is still writing to — the data keeps
  # flowing into the unlinked inode but the directory entry is gone after greedy exits,
  # leaving the outer script with no log to read for the FOUND-block extraction.
  if [ -z "${_QUIBBLE_NESTED_BATCH:-}" ]; then
    rm -f "$QUIBBLE_LOG_DIR"/*.log # clear old logs to avoid confusion from stale results (scoped to this run's dir, so concurrent workers don't wipe each other)
  fi
fi

# Track results for summary
failed="" # newline-separated list of failed items
passed="" # newline-separated list of passed items

# Run a command, print what it does, and record pass/fail.
# Usage: run_step COMPONENT COMMAND [ARGS...]
# COMPONENT: name for tracking (e.g. "core" or "extensions/Echo")
# COMMAND: the command to run (e.g. ./fresh_install)
run_step() {
  local component="$1" # component name for tracking
  shift                 # remove first arg; remaining args ("$@") are the command to run
  local step="${1##*/}" # extract script name from path (e.g. ./fresh_install -> fresh_install)
  local step_start=$SECONDS # capture start time for step duration

  if [ -n "$verbose" ]; then
    # Verbose: print separator and run command with full output
    printf "\n========================================\n"
    printf "= %s: %s %s\n" "$component" "$*" "$(utc_timestamp)" # $* joins all args into a single string
    printf "========================================\n"
    if "$@"; then # run the command (all remaining arguments)
      # Print standalone duration line only when TIME_ELAPSED=1; otherwise the bare "()" line would clutter every verbose step.
      [ -n "${TIME_ELAPSED:-}" ] && printf "(%s)\n" "$(_quibble_format_duration "$((SECONDS - step_start))")"
      return 0 # step passed
    else
      [ -n "${TIME_ELAPSED:-}" ] && printf "(%s)\n" "$(_quibble_format_duration "$((SECONDS - step_start))")"
      failed="$failed
  $component ($step)" # append component and failed step on a new indented line
      return 1 # step failed, caller can skip remaining steps
    fi
  else
    # Silent: print step label, save output to log file, print a dot per line, then (on
    # failure) FAIL with duration. On success only the dots and optional duration remain.
    local log_file="$QUIBBLE_LOG_DIR/${component//\//-}--${step}.log" # e.g. log/silent/extensions-Echo--install.log
    printf "%s " "$step" # print step name before dots (e.g. "fresh_install ")
    if run_with_dots "$log_file" "$@"; then # run command, print dots, check exit code
      # Success: the dots are the only feedback — no redundant "ok". Print just the elapsed time
      # (when TIME_ELAPSED=1) plus a trailing space separating this step from the next on the line.
      # _quibble_format_duration_padded returns " (Ns)" when TIME_ELAPSED=1, empty otherwise.
      printf "%s " "$(_quibble_format_duration_padded "$((SECONDS - step_start))")"
      return 0
    else
      printf " FAIL%s " "$(_quibble_format_duration_padded "$((SECONDS - step_start))")"
      failed="$failed
  $component ($step)" # append component and failed step on a new indented line
      return 1
    fi
  fi
}

# shellcheck shell=bash
# Greedy algorithm: start with all deps, remove one at a time.
# O(N) instead of O(2^N). For each optional dep, try removing it.
# If tests still pass without it, it's not needed.
# Must be sourced, not run directly.
# Expects these variables/functions to be set by the caller:
#   component       — e.g. "extensions/Echo"
#   optional        — indexed array of optional dependency names
#   n               — number of optional dependencies
#   required_str    — space-separated list of required dependency names
#   required        — indexed array of required dependency names
#   fresh_or_restore — function to set up core MediaWiki (fresh_install or restore)
#   run_step        — function from lib/batch_setup for progress tracking
# Sets:
#   optional_combo  — space-separated list of minimum optional deps found
# shellcheck disable=SC2154 # variables are set by the sourcing script

printf "\nGreedy mode: starting with all %d optional deps, removing one at a time.\n" "$n"

# Start with all optional deps as "kept" (indices into the optional array)
kept=() # indices of optional deps still included
for i in $(seq 0 $((n - 1))); do
  kept+=("$i") # start with all optional deps
done

# First, verify tests pass with all dependencies
printf "\n=== Baseline: all dependencies === %s\n" "$(utc_timestamp)"
if ! fresh_or_restore; then
  printf "SKIP (fresh_install/restore failed)\n"
  printf "\nCannot establish baseline.\n"
  exit 1
fi

# Build optional_combo from all optional deps for baseline test
optional_combo=""
if [ "$n" -gt 0 ]; then
  for dep in "${optional[@]}"; do
    optional_combo="${optional_combo:+$optional_combo }$dep" # space-separated
  done
fi
. "$(dirname "$0")"/lib/build_full_combo

export QUIBBLE_DEPS="$full_combo"
if ! run_step "$component" ./install "$component"; then
  unset QUIBBLE_DEPS
  printf "\nBaseline install failed with all dependencies.\n"
  exit 1
fi
unset QUIBBLE_DEPS

if ! run_step "$component" ./run_selenium_tests "$component"; then
  printf "\nBaseline tests failed with all dependencies. Cannot determine minimum.\n"
  exit 1
fi

# Try removing each optional dep one at a time
for i in $(seq 0 $((n - 1))); do
  dep="${optional[$i]}"
  printf "\n=== Try removing %s (%d/%d) === %s\n" "$dep" "$((i + 1))" "$n" "$(utc_timestamp)"

  # Build optional_combo without this dep (using kept indices, excluding i)
  new_kept=() # candidate kept list without current dep
  for k in "${kept[@]}"; do
    [ "$k" -eq "$i" ] && continue # skip the dep we're trying to remove
    new_kept+=("$k")
  done

  # Build optional_combo from new_kept indices
  optional_combo=""
  if [ ${#new_kept[@]} -gt 0 ]; then
    for k in "${new_kept[@]}"; do
      optional_combo="${optional_combo:+$optional_combo }${optional[k]}" # space-separated
    done
  fi
  . "$(dirname "$0")"/lib/build_full_combo

  if ! fresh_or_restore; then
    printf "SKIP (fresh_install/restore failed), keeping %s\n" "$dep"
    continue # keep this dep (can't test without it)
  fi

  export QUIBBLE_DEPS="$full_combo"
  if ! run_step "$component" ./install "$component"; then
    unset QUIBBLE_DEPS
    printf "Install failed without %s, keeping it\n" "$dep"
    continue # keep this dep
  fi
  unset QUIBBLE_DEPS

  if run_step "$component" ./run_selenium_tests "$component"; then
    printf "Tests passed without %s, removing it\n" "$dep"
    kept=("${new_kept[@]}") # permanently remove this dep
  else
    printf "Tests failed without %s, keeping it\n" "$dep"
    # kept stays unchanged (dep remains)
  fi
done

# Build final optional_combo from kept indices
optional_combo=""
if [ ${#kept[@]} -gt 0 ]; then
  for k in "${kept[@]}"; do
    optional_combo="${optional_combo:+$optional_combo }${optional[k]}" # space-separated
  done
fi

# Print results
. "$(dirname "$0")"/lib/print_found

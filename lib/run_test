# shellcheck shell=bash
# Provides run_test function for test_integration-style scripts.
# Runs a command, prints what it does, and records pass/fail in $passed/$failed.
# In verbose mode: prints separator box and full output to terminal.
# In silent mode: saves output to a numbered log file (e.g. log/silent/01-help.log)
# and prints a dot per line of output.
# Must be sourced after lib/batch_setup (which provides $verbose, $passed, $failed,
# run_with_dots, _quibble_format_duration, utc_timestamp).
# Sourced by test_integration and test_integration_slow.
# Usage: run_test ./help
#        run_test env QUIBBLE_DEPS="" ./install extensions/Echo
# shellcheck disable=SC2154 # verbose, failed, and passed are set by lib/batch_setup

test_counter=0 # counter for silent mode log file names

# Run a command and record whether it passed or failed
run_test() {
  local test_start=$SECONDS # capture start time for test duration
  if [ -n "$verbose" ]; then
    # Verbose: print separator and run command with full output
    printf "\n========================================\n"
    printf "= Running: %s %s\n" "$*" "$(utc_timestamp)" # $* joins all args into a single string
    printf "========================================\n"
    if "$@"; then # run the command (all arguments passed to this function)
      # Print standalone duration line only when TIME_ELAPSED=1; otherwise the bare "()" line would clutter every verbose test.
      [ -n "${TIME_ELAPSED:-}" ] && printf "(%s)\n" "$(_quibble_format_duration "$((SECONDS - test_start))")"
      passed="$passed
  $*" # append full command on a new indented line
    else
      [ -n "${TIME_ELAPSED:-}" ] && printf "(%s)\n" "$(_quibble_format_duration "$((SECONDS - test_start))")"
      failed="$failed
  $*" # append full command on a new indented line
    fi
  else
    # Silent: save output to log file, print a dot per line of output, then (on failure)
    # FAIL with duration. On success only the dots and optional duration/timestamp remain.
    test_counter=$((test_counter + 1)) # increment counter for unique log file names
    local log_file
    log_file=$(printf "%s/%02d-%s.log" "${QUIBBLE_LOG_DIR:-log/silent}" "$test_counter" "${1##*/}") # e.g. log/silent/03-prepare.log (QUIBBLE_LOG_DIR set by lib/batch_setup, sourced first)
    printf "%s " "$*" # print full command without newline
    if run_with_dots "$log_file" "$@"; then # run command, print dots, check exit code
      # Success: the dots are the only feedback — no redundant "ok". Print just the elapsed time
      # (when TIME_ELAPSED=1) and UTC timestamp (when TIME_UTC=1); each is empty when its gate is off.
      printf "%s %s\n" "$(_quibble_format_duration_padded "$((SECONDS - test_start))")" "$(utc_timestamp)"
      passed="$passed
  $*" # append full command on a new indented line
    else
      printf " FAIL%s %s\n" "$(_quibble_format_duration_padded "$((SECONDS - test_start))")" "$(utc_timestamp)"
      failed="$failed
  $*" # append full command on a new indented line
    fi
  fi
}

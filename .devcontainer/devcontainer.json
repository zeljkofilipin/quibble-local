// Dev container config for quibble-local development.
// Reference: https://containers.dev/implementors/json_reference/
{
  "name": "quibble-local",

  // Ubuntu base image — matches one of the project's supported OSes (macOS/Ubuntu),
  // so scripts behave the same as on a native Ubuntu host.
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  // Install shellcheck (for ./lint), bats (for ./test_unit), and Claude Code CLI
  // via the official native installer (npm install is deprecated).
  // The native installer drops `claude` into ~/.local/bin, which is on PATH for
  // the default `vscode` user in the base image.
  //
  // No Docker access by design: the devcontainer is Claude's sandbox, and
  // mounting the host Docker socket would let it escape to the host. Project
  // scripts that need Docker (./ci, ./fresh_install, ./test_integration, etc.)
  // must be run on the host directly.
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends shellcheck bats && curl -fsSL https://claude.ai/install.sh | bash",

  // Persist Claude Code state (auto-memory, credentials, sessions, settings)
  // across devcontainer rebuilds by bind-mounting a host directory. Stored
  // outside the repo so personal state (credentials, sessions) cannot be
  // accidentally committed. `initializeCommand` runs on the host before build
  // and ensures the directory exists (Docker errors on a missing bind source
  // rather than auto-creating it).
  //
  // It also seeds a user-scope `settings.json` with `bypassPermissions` so
  // Claude does not prompt for tool use inside the container. The container is
  // Claude's sandbox; per-tool prompts are redundant inside it. Kept at user
  // scope (this bind-mounted ~/.claude) rather than project scope so it does
  // NOT apply when running Claude on the host. The seed runs only if the file
  // is missing, so manual edits on either machine are preserved.
  "initializeCommand": "mkdir -p ${localEnv:HOME}/.claude-devcontainers/quibble-local && { [ -f ${localEnv:HOME}/.claude-devcontainers/quibble-local/settings.json ] || echo '{\"permissions\":{\"defaultMode\":\"bypassPermissions\"}}' > ${localEnv:HOME}/.claude-devcontainers/quibble-local/settings.json; }",
  "mounts": [
    "source=${localEnv:HOME}/.claude-devcontainers/quibble-local,target=/home/vscode/.claude,type=bind"
  ],

  // Ensure the bind-mounted directory is owned by the `vscode` user inside the
  // container. On Docker Desktop (Mac/Windows) this is a no-op (fakeowner), but
  // on native Linux the host UID may not match, which would block Claude Code
  // from writing to ~/.claude/.
  "postStartCommand": "sudo chown -R vscode:vscode /home/vscode/.claude",

  "customizations": {
    "vscode": {
      // Extensions that match the tools used in this repo.
      "extensions": [
        "timonwong.shellcheck"
      ]
    }
  }
}

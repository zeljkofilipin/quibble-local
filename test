#!/usr/bin/env bash
#
# Run all scripts and report which ones passed or failed.
# Useful for detecting regressions after changes.
# WARNING: This will take a long time to run.
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./test
#

# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/inhibit_sleep # prevent the machine from suspending
. "$(dirname "$0")"/lib/print_results # provides print_results function
failed="" # newline-separated list of failed commands (with arguments)
passed="" # newline-separated list of passed commands (with arguments)

# Run a command and record whether it passed or failed
run_test() {
  printf "\n========================================\n"
  printf "= Running: %s\n" "$*"
  printf "========================================\n"
  if "$@"; then
    passed="$passed
  $*" # append full command on a new indented line
  else
    failed="$failed
  $*" # append full command on a new indented line
  fi
}

# Run each script in order (some depend on earlier ones)
run_test ./help
run_test ./lint
run_test ./prepare
run_test ./fresh_install
run_test ./selenium_tests_exist
run_test ./run_selenium_tests
run_test ./run_selenium_tests --spec tests/selenium/wdio-mediawiki/specs/BlankPage.js
run_test ./run_selenium_tests --spec tests/selenium/specs/user.js --mochaOpts.grep "should be able to create account"
run_test ./install extensions/Echo
run_test ./dependencies extensions/Echo
run_test ./gated
run_test ./selenium_tests_exist extensions/Echo
run_test ./run_selenium_tests extensions/Echo
run_test ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/notifications.js
run_test ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/notifications.js --mochaOpts.grep "alerts and notices are visible"
run_test ./install extensions/CampaignEvents
run_test ./run_selenium_tests extensions/CampaignEvents
run_test ./fetch
run_test ./clean

# Print pass/fail summary and exit with error if any script failed
print_results

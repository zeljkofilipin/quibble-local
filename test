#!/usr/bin/env bash
#
# Run all scripts and report which ones passed or failed.
# Useful for detecting regressions after changes.
#
# Usage: ./test
#

# No set -euo pipefail: we want to continue after failures to collect all results
failed="" # space-separated list of failed script names
passed="" # space-separated list of passed script names

# Run a command and record whether it passed or failed
run_test() {
  printf "\n========================================\n"
  printf "= Running: %s\n" "$*"
  printf "========================================\n"
  if "$@"; then
    passed="$passed $1" # add script name to passed list
  else
    failed="$failed $1" # add script name to failed list
  fi
}

# Run each script in order (some depend on earlier ones)
run_test ./help
run_test ./lint
run_test ./prepare
run_test ./fresh_install
run_test ./run_selenium_tests
run_test ./run_selenium_tests --spec tests/selenium/wdio-mediawiki/specs/BlankPage.js
run_test ./run_selenium_tests --spec tests/selenium/specs/user.js --mochaOpts.grep "should be able to create account"
run_test ./install extensions/Echo
run_test ./dependencies extensions/Echo
run_test ./run_selenium_tests extensions/Echo
run_test ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/echo.js
run_test ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/echo.js --mochaOpts.grep "alerts and notices are visible"
run_test ./install extensions/CampaignEvents
run_test ./run_selenium_tests extensions/CampaignEvents
run_test ./fetch
run_test ./clean

# Print summary of results
printf "\n========================================\n"
printf "= Results\n"
printf "========================================\n"

if [ -n "$passed" ]; then
  printf "PASSED:%s\n" "$passed"
fi

if [ -n "$failed" ]; then
  printf "FAILED:%s\n" "$failed"
  exit 1 # exit with error if any script failed
fi

printf "\nAll scripts passed.\n"

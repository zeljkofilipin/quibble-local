#!/usr/bin/env bash
#
# Run all scripts and report which ones passed or failed.
# Useful for detecting regressions after changes.
# WARNING: This will take a long time to run.
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./test
#        VERBOSE=1 ./test
#

# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking

test_counter=0 # counter for silent mode log file names

# Run a command and record whether it passed or failed
run_test() {
  if [ -n "$verbose" ]; then
    # Verbose: print separator and run command with full output
    printf "\n========================================\n"
    printf "= Running: %s\n" "$*" # $* joins all args into a single string
    printf "========================================\n"
    if "$@"; then # run the command (all arguments passed to this function)
      passed="$passed
  $*" # append full command on a new indented line
    else
      failed="$failed
  $*" # append full command on a new indented line
    fi
  else
    # Silent: save output to log file, print a dot per line of output, then ok or FAIL
    test_counter=$((test_counter + 1)) # increment counter for unique log file names
    local log_file
    log_file=$(printf "log/silent/%02d-%s.log" "$test_counter" "${1##*/}") # e.g. log/silent/03-prepare.log
    printf "%s " "$*" # print full command without newline
    if run_with_dots "$log_file" "$@"; then # run command, print dots, check exit code
      printf " ok %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')" # success with UTC timestamp
      passed="$passed
  $*" # append full command on a new indented line
    else
      printf " FAIL %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')" # failure with UTC timestamp
      failed="$failed
  $*" # append full command on a new indented line
    fi
  fi
}

# Run each script in order (some depend on earlier ones)
run_test ./help                        # test that help output works
run_test ./lint                        # test that all scripts pass shellcheck
run_test ./ci                          # test that CI lint passes in Docker
run_test ./prepare                     # test that prepare pulls image and clones repos
run_test ./fresh_install               # test fresh core install
run_test ./selenium_tests_exist        # test that core has Selenium tests
run_test ./run_selenium_tests          # test running all core Selenium tests
run_test ./run_selenium_tests --spec tests/selenium/wdio-mediawiki/specs/BlankPage.js  # test running a specific test file
run_test ./run_selenium_tests --spec tests/selenium/specs/user.js --mochaOpts.grep "should be able to create account"  # test filtering by grep pattern
run_test ./install extensions/Echo     # test installing an extension
run_test ./dependencies extensions/Echo  # test listing extension dependencies
run_test ./required_dependencies extensions/Echo  # test listing required dependencies
run_test ./optional_dependencies extensions/Echo  # test listing optional dependencies
run_test ./gated                       # test listing gated repos
run_test ./selenium_tests_exist extensions/Echo  # test that extension has Selenium tests
run_test ./run_selenium_tests extensions/Echo  # test running extension Selenium tests
run_test ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/notifications.js  # test running a specific extension test file
run_test ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/notifications.js --mochaOpts.grep "alerts and notices are visible"  # test filtering extension tests by grep
run_test ./install extensions/CampaignEvents  # test installing another extension
run_test ./run_selenium_tests extensions/CampaignEvents  # test running another extension's tests
run_test ./fetch                       # test fetching latest changes
run_test ./clean                       # test cleaning up src/

# Print pass/fail summary and exit with error if any script failed
print_results

#!/usr/bin/env bash
#
# Remove src/ (MediaWiki source code).
# Use ./deep_clean to remove everything quibble-local created.
# WARNING: This will delete all MediaWiki source code in src/.
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/setup # source shared setup (enables trace output)

# Use Docker (as root) to remove files owned by the container user.
docker run --rm \
  --entrypoint bash \
  --user root \
  -v "$QUIBBLE_DIR"/src:/workspace/src \
  "$QUIBBLE_IMAGE" \
  -c 'find /workspace/src -mindepth 1 -delete' # delete contents but not the mount point itself

# Remove the now-empty src/ directory from the host
rm -rf src

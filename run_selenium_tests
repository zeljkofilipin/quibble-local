#!/usr/bin/env bash
#
# Run Selenium tests. Skips installation (assumes ./fresh_install or ./install has been run first).
#
# Usage: ./run_selenium_tests
#        ./run_selenium_tests extensions/Echo
#        ./run_selenium_tests --spec tests/selenium/specs/page.js
#        ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/notifications.js
#        ./run_selenium_tests --spec tests/selenium/specs/user.js --mochaOpts.grep "should be able to create account"
#        ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/notifications.js --mochaOpts.grep "alerts and notices are visible"
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Build optional ZUUL_PROJECT env var if an extension/skin was specified
zuul_project=() # empty array by default
wdio_args=() # extra arguments to pass to wdio (e.g. --spec)

# Parse arguments: first arg may be a component (extensions/X or skins/X),
# remaining args are passed through to wdio
while [ $# -gt 0 ]; do
  case "$1" in
    extensions/* | skins/*) # component path (e.g. extensions/Echo)
      component="$1"
      repo="mediawiki/${component}"
      # Tell Quibble which extension/skin to target
      zuul_project=(-e "ZUUL_PROJECT=${repo}")
      shift
      ;;
    *) # everything else is a wdio argument (e.g. --spec file.js)
      wdio_args+=("$1")
      shift
      ;;
  esac
done

. "$(dirname "$0")"/lib # source shared setup (enables trace output)

# Decide how to run tests:
# - with --spec + component: cd into component dir, then run specific test
# - with --spec (no component): run specific test from repo root
# - without --spec: use --run selenium to run all tests
if [ ${#wdio_args[@]} -gt 0 ]; then
  # For extensions/skins, cd into the component directory first
  if [ -n "${component:-}" ]; then
    quibble_args=(--command "cd ${component} && npm run selenium-test -- ${wdio_args[*]}")
  else
    quibble_args=(--command "npm run selenium-test -- ${wdio_args[*]}")
  fi
else
  # Run all Selenium tests
  quibble_args=(--run selenium)
fi

# Run Selenium tests in the container
# -e CI=true: tell Quibble this is a CI run
# --skip-zuul: don't clone repos (already in src/)
# --skip-deps: don't install dependencies (already installed)
# ${zuul_project[@]+"..."}: expand array only if non-empty (bash 3.2 compat)
docker run -it --rm \
  --entrypoint=quibble-with-supervisord \
  -p 9413:9413 \
  "${QUIBBLE_VOLUMES[@]}" \
  -e CI=true \
  ${zuul_project[@]+"${zuul_project[@]}"} \
  "$QUIBBLE_IMAGE" \
  --skip-zuul \
  --skip-deps \
  "${quibble_args[@]}"

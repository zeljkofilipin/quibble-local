#!/usr/bin/env bash
#
# Run Selenium tests. Assumes ./fresh_install has been run first.
#
# Usage: ./run_selenium_tests
#        ./run_selenium_tests extensions/Echo
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble
#
set -euo pipefail

zuul_project=()

if [ $# -gt 0 ]; then
  component="$1"
  repo="mediawiki/${component}"
# Tell Quibble which extension/skin to target
  zuul_project=(-e "ZUUL_PROJECT=${repo}")
fi

. "$(dirname "$0")"/lib

docker run -it --rm \
  --entrypoint=quibble-with-supervisord \
  -p 9413:9413 \
  -v "$(pwd)"/cache:/cache \
  -v "$(pwd)"/log:/workspace/log \
  -v "$(pwd)"/ref:/srv/git:ro \
  -v "$(pwd)"/src:/workspace/src \
  -e CI=true \
  ${zuul_project[@]+"${zuul_project[@]}"} \
  docker-registry.wikimedia.org/releng/quibble-bullseye-php83:latest \
  --skip-zuul \
  --skip-deps \
  --run selenium
# --skip-zuul: don't clone repos (already in src/)
# --skip-deps: don't install dependencies (already installed)
# ${zuul_project[@]+"..."}: expand array only if non-empty (bash 3.2 compat)

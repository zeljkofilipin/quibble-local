#!/usr/bin/env bash
#
# Run Selenium tests. Skips installation (assumes ./fresh_install or ./install has been run first).
#
# Usage: ./run_selenium_tests
#        ./run_selenium_tests extensions/Echo
#        ENVIRONMENT=0 ./run_selenium_tests extensions/Echo
#        ./run_selenium_tests --spec tests/selenium/specs/page.js
#        ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/notifications.js
#        ./run_selenium_tests --spec tests/selenium/specs/user.js --mochaOpts.grep "should be able to create account"
#        ./run_selenium_tests extensions/Echo --spec tests/selenium/specs/notifications.js --mochaOpts.grep "alerts and notices are visible"
#        DRY_RUN=1 ./run_selenium_tests extensions/Echo  # pass --dry-run to Quibble (no real run)
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Parse optional component (extensions/X or skins/X) and extra arguments (e.g. --spec).
# Sets: component, zuul_project, extra_args
. "$(dirname "$0")"/lib/parse_component_args

# Decide how to run tests:
# - with --spec + component: cd into component dir, then run specific test
# - with --spec (no component): run specific test from repo root
# - without --spec: use --run selenium to run all tests
# ${#arr[@]} gets the number of elements in the array
if [ ${#extra_args[@]} -gt 0 ]; then
  if [ -n "$component" ]; then # for extensions/skins, cd into the component directory first
    quibble_args=(--command "cd ${component} && npm run selenium-test -- ${extra_args[*]}")
  else
    quibble_args=(--command "npm run selenium-test -- ${extra_args[*]}")
  fi
else
  # Run all Selenium tests
  quibble_args=(--run selenium)
fi

. "$(dirname "$0")"/lib/setup # source shared setup (trace output in verbose mode only)
. "$(dirname "$0")"/lib/run_quibble_test # provides run_quibble_test function

# Run Selenium tests in the container
run_quibble_test "${quibble_args[@]}"

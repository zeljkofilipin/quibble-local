#!/usr/bin/env bash
#
# Output dependencies for an extension or skin.
#
# Usage: ./dependencies extensions/Echo
#        ./dependencies skins/MinervaNeue
#        VERBOSE=1 ./dependencies extensions/Echo
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/debug_info # print debug info, check prerequisites, show verbose hint

# Show usage if no argument provided
if [ $# -eq 0 ]; then
  echo "Usage: ./dependencies extensions/EXTENSION or ./dependencies skins/SKIN"
  exit 1
fi

# Get the component from the first argument (e.g. "extensions/Echo")
component="$1"

# Strip "extensions/" prefix if present (skins/ is kept as-is)
# dependencies.yaml uses bare names for extensions but "skins/Name" for skins
if [[ "$component" == extensions/* ]]; then
  dep_key="${component#extensions/}" # remove "extensions/" prefix
else
  dep_key="$component" # keep as-is (e.g. "skins/MinervaNeue")
fi

# Parse dependencies.yaml with awk:
# -v key="Name:" passes the dependency key as an awk variable
# $0==key{f=1;next}     — when current line matches the key, set flag and skip to next line
# f&&/^[^ ]/{exit}      — if flag set and line starts with non-space, we've left the list, stop
# f&&/^ *- /{sub(...);print} — strip the "  - " YAML list prefix and print the dependency name
awk -v key="${dep_key}:" '$0==key{f=1;next} f&&/^[^ ]/{exit} f&&/^ *- /{sub(/^ *- /,"");print}' src/config/zuul/dependencies.yaml

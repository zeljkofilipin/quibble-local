#!/usr/bin/env bash
#
# Remove all src directories across all environments.
# This removes src/, src_save/, src_N/, src_save_N/, and src_worker_N/.
# Keeps ref/ (bare repos), cache/, log/, and the Docker image.
# Use ./clean to remove only the current environment's src/.
# Use ./clean_deep to remove everything quibble-local created.
# WARNING: This will delete all MediaWiki source code in all environments.
#
# Usage: ./clean_src
#        VERBOSE=1 ./clean_src
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/setup # source shared setup (trace output in verbose mode only)

# Collect all src-related directories that exist.
# Glob patterns: src, src_save, src_N, src_save_N, src_worker_N.
# printf '%s ' ... 2>/dev/null: suppress "no matches found" error if glob matches nothing.
# shellcheck disable=SC2046 # intentional word splitting: glob expansion of src_* paths
src_dirs=$(printf '%s ' src src_save $(printf '%s ' src_[0-9]* src_save_[0-9]* src_worker_* 2>/dev/null))

# Build Docker volume mount flags for directories that exist
volumes="" # -v flags for docker run
paths="" # container paths for find command
for dir in $src_dirs; do
  # shellcheck disable=SC2086 # intentional word splitting of src_dirs
  [ -d "$dir" ] || continue # skip directories that don't exist
  volumes="$volumes -v $QUIBBLE_DIR/$dir:/workspace/$dir"
  paths="$paths /workspace/$dir"
done

if [ -n "$paths" ]; then
  # Use Docker (as root) to remove files owned by the container user.
  # --rm: remove container on exit
  # --entrypoint bash: override default entrypoint to run a shell command
  # --user root: run as root to have permission to delete all files
  # -v: mount each src dir so we can delete its contents from inside the container
  # shellcheck disable=SC2086 # intentional word splitting of volume flags and paths
  docker run --rm \
    --entrypoint bash \
    --user root \
    $volumes \
    "$QUIBBLE_IMAGE" \
    -c "find $paths -mindepth 1 -delete" # delete contents but not mount points
fi

# Remove the now-empty directories from the host
# shellcheck disable=SC2086 # intentional word splitting of src_dirs
rm -rf $src_dirs

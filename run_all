#!/usr/bin/env bash
#
# Run Selenium tests for core and all gated repositories.
# For each component: fresh_install, install (if not core),
# check if Selenium tests exist, and run them.
# WARNING: This will take a very long time to run (50+ components).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./run_all
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Prevent the machine from suspending while this long-running script is active
if [ "$(uname)" = "Darwin" ]; then
  caffeinate -s -w $$ & # macOS: prevent sleep while this process is alive
else
  systemd-inhibit --what=sleep --who=run_all --why="Quibble tests running" sleep infinity &
  inhibit_pid=$!                          # save PID to kill on exit
  trap 'kill $inhibit_pid 2>/dev/null' EXIT # clean up on script exit
fi

# Track results for summary
failed="" # space-separated list of failed components
passed="" # space-separated list of passed components

# Run a command, print what it does, and record pass/fail
run_step() {
  local component="$1" # component name for tracking (e.g. "core" or "extensions/Echo")
  shift                 # remaining args are the command to run
  printf "\n========================================\n"
  printf "= %s: %s\n" "$component" "$*"
  printf "========================================\n"
  if "$@"; then
    return 0 # step passed
  else
    failed="$failed $component" # record failure
    return 1 # step failed, caller can skip remaining steps
  fi
}

# --- Core ---
printf "\n########################################\n"
printf "# Core\n"
printf "########################################\n"
if run_step core ./fresh_install; then
  if ./selenium_tests_exist; then
    run_step core ./run_selenium_tests
  fi
  passed="$passed core"
fi

# --- Gated repositories ---
while IFS= read -r component <&3; do # read from fd 3 so stdin stays free for docker
  printf "\n########################################\n"
  printf "# %s\n" "$component"
  printf "########################################\n"
  if run_step "$component" ./fresh_install; then
    if run_step "$component" ./install "$component"; then
      if ./selenium_tests_exist "$component"; then
        run_step "$component" ./run_selenium_tests "$component"
      fi
    fi
  fi
  # Record as passed if not already in failed list
  case "$failed" in
    *"$component"*) ;; # already recorded as failed
    *) passed="$passed $component" ;; # add to passed list
  esac
done 3< <(./gated) # feed gated list via fd 3 (not stdin, which docker needs)

# --- Summary ---
printf "\n########################################\n"
printf "# Results\n"
printf "########################################\n"

if [ -n "$passed" ]; then
  printf "PASSED:%s\n" "$passed"
fi

if [ -n "$failed" ]; then
  printf "FAILED:%s\n" "$failed"
  exit 1 # exit with error if any component failed
fi

printf "\nAll components passed.\n"

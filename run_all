#!/usr/bin/env bash
#
# Run Selenium tests for core and all gated repositories.
# For each component: fresh_install, install (if not core),
# check if Selenium tests exist, and run them.
# WARNING: This will take a very long time to run (50+ components).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./run_all
#
# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/inhibit_sleep # prevent the machine from suspending
. "$(dirname "$0")"/lib/print_results # provides print_results function

# Track results for summary
failed="" # space-separated list of failed components
passed="" # space-separated list of passed components

# Run a command, print what it does, and record pass/fail
run_step() {
  local component="$1" # component name for tracking (e.g. "core" or "extensions/Echo")
  shift                 # remove first arg; remaining args ("$@") are the command to run
  # print a visual separator with the component name and command
  printf "\n========================================\n"
  printf "= %s: %s\n" "$component" "$*" # $* joins all args into a single string
  printf "========================================\n"
  if "$@"; then # run the command (all remaining arguments)
    return 0 # step passed
  else
    failed="$failed $component" # record failure
    return 1 # step failed, caller can skip remaining steps
  fi
}

# --- Core ---
# print section header for core
printf "\n########################################\n"
printf "# Core\n"
printf "########################################\n"
if run_step core ./fresh_install; then # install core; skip remaining steps if this fails
  if ./selenium_tests_exist; then # check if core has Selenium tests
    run_step core ./run_selenium_tests # run core Selenium tests
  fi
  passed="$passed core" # record core as passed
fi

# --- Gated repositories ---
# IFS= preserves whitespace in component names; -r prevents backslash interpretation.
# <&3 reads from file descriptor 3 instead of stdin, because docker's -it flag needs stdin.
# 3< <(...) is process substitution: runs ./gated and connects its output to fd 3.
while IFS= read -r component <&3; do
  # print section header for this component
  printf "\n########################################\n"
  printf "# %s\n" "$component"
  printf "########################################\n"
  if run_step "$component" ./fresh_install; then # install core; skip remaining steps if this fails
    if run_step "$component" ./install "$component"; then # install extension/skin; skip tests if this fails
      if ./selenium_tests_exist "$component"; then # check if this component has Selenium tests
        run_step "$component" ./run_selenium_tests "$component" # run Selenium tests
      fi
    fi
  fi
  # Record as passed if not already in failed list
  case "$failed" in
    *"$component"*) ;; # already recorded as failed
    *) passed="$passed $component" ;; # add to passed list
  esac
done 3< <(./gated) # feed gated list via fd 3 (not stdin, which docker needs)

# Print pass/fail summary and exit with error if any component failed
print_results

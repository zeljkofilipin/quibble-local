#!/usr/bin/env bash
#
# Run Selenium tests for core and all gated repositories (or a single component).
# For each component: fresh_install, install (if not core),
# check if Selenium tests exist, and run them.
# WARNING: Without arguments, this will take a very long time to run (50+ components).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./run_all
#        ./run_all extensions/Echo
#        VERBOSE=1 ./run_all
#        FAST=1 ./run_all
#        PARALLEL=$(./suggested_parallel) ./run_all
#        PARALLEL=4 FAST=1 ./run_all
# FAST=1: Runs fresh_install once, saves state, then restores instead of re-running fresh_install.
# PARALLEL=N: Run N components in parallel (each in isolated src_worker_$i/ directory).
#             Use ./suggested_parallel to determine N for your machine.
#
# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking
fast="${FAST:-}" # FAST=1 saves fresh_install state and restores instead of re-running
parallel="${PARALLEL:-1}" # PARALLEL=N runs N components in parallel (default 1 = sequential)

# --- Core ---
print_header "core"
if run_step core ./fresh_install; then # install core; skip remaining steps if this fails
  # Save state after first fresh_install for fast mode
  if [ -n "$fast" ]; then
    run_step core ./save
  fi
  if ./selenium_tests_exist; then # check if core has Selenium tests
    run_step core ./run_selenium_tests # run core Selenium tests
  fi
  record_passed "core"
fi
printf " %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')" # print UTC timestamp after core

# --- Build list of gated components ---
components=() # array of component names to process
if [ $# -gt 0 ]; then
  components+=("$1") # single component from argument
else
  while IFS= read -r component; do
    components+=("$component") # += appends to bash arrays
  done < <("$(dirname "$0")"/gated)
fi
total=${#components[@]} # total number of gated components

if [ "$parallel" -le 1 ]; then
  # --- Sequential mode ---
  # IFS= preserves whitespace in component names; -r prevents backslash interpretation.
  # <&3 reads from file descriptor 3 instead of stdin, because docker's -it flag needs stdin.
  # 3< <(...) is process substitution: connects array output to fd 3.
  while IFS= read -r component <&3; do
    print_header "$component"
    # Restore from saved state in fast mode, or run fresh_install
    if [ -n "$fast" ] && [ -d src_save ]; then
      core_ok=false; run_step "$component" ./restore && core_ok=true
    else
      core_ok=false; run_step "$component" ./fresh_install && core_ok=true
    fi
    if [ "$core_ok" = true ]; then # skip remaining steps if core setup fails
      if run_step "$component" ./install "$component"; then # install extension/skin; skip tests if this fails
        if ./selenium_tests_exist "$component"; then # check if this component has Selenium tests
          run_step "$component" ./run_selenium_tests "$component" # run Selenium tests
        fi
      fi
    fi
    record_passed "$component"
    printf " %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')" # print UTC timestamp after component
  done 3< <(printf '%s\n' "${components[@]}")

else
  # --- Parallel mode ---
  printf "\nParallel mode: %d workers\n" "$parallel"

  if [ -n "$fast" ] && [ ! -d src_save ]; then
    # Ensure src_save/ exists for workers to restore from (core was already installed above)
    printf "\nError: FAST mode requires src_save/ (run ./save first or let core step create it).\n"
    exit 1
  fi

  # Create result directory for workers to report pass/fail
  result_dir=$(mktemp -d) # temp dir for worker result files

  # Process components in waves of $parallel workers
  wave_start=0 # index into components array for start of current wave
  while [ "$wave_start" -lt "$total" ]; do
    wave_end=$((wave_start + parallel)) # exclusive end index
    if [ "$wave_end" -gt "$total" ]; then
      wave_end="$total" # last wave may be smaller
    fi
    wave_size=$((wave_end - wave_start))

    printf "\n--- Wave %d-%d of %d (%d workers) --- %s\n" \
      "$((wave_start + 1))" "$wave_end" "$total" "$wave_size" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"

    # Launch workers for this wave
    pids=() # array of background process IDs
    worker=0 # worker index (0-based, used for src_worker_$worker/)
    while [ "$worker" -lt "$wave_size" ]; do
      comp_idx=$((wave_start + worker))
      component="${components[$comp_idx]}"
      worker_src="src_worker_$((worker + 1))" # isolated src directory (1-based for readability)
      worker_log="log/silent/worker-$((worker + 1))" # per-worker log directory

      mkdir -p "$worker_src" "$worker_log" # create worker directories

      printf "  Worker %d: %s\n" "$((worker + 1))" "$component"

      # Launch worker in background subshell.
      # Each worker runs in its own src directory: restore/fresh_install → install → run_selenium_tests.
      # QUIBBLE_SRC: isolated src directory for this worker
      # QUIBBLE_BACKGROUND=1: skip -i/-t Docker flags (no stdin in background)
      # Worker writes "pass" or "fail" to a result file.
      (
        export QUIBBLE_SRC="$worker_src"
        export QUIBBLE_BACKGROUND=1

        # Redirect all output to worker log file
        exec > "$worker_log/${component//\//-}.log" 2>&1

        # Set up core MediaWiki
        if [ -n "$fast" ]; then
          # Fast mode: restore from saved state
          if ! ./restore; then
            echo "fail" > "$result_dir/worker_$comp_idx"
            exit 1
          fi
        else
          # Normal mode: fresh_install from scratch
          if ! ./fresh_install; then
            echo "fail" > "$result_dir/worker_$comp_idx"
            exit 1
          fi
        fi

        # Install extension/skin
        if ! ./install "$component"; then
          echo "fail" > "$result_dir/worker_$comp_idx"
          exit 1
        fi

        # Run Selenium tests if they exist
        if ./selenium_tests_exist "$component"; then
          if ./run_selenium_tests "$component"; then
            echo "pass" > "$result_dir/worker_$comp_idx"
          else
            echo "fail" > "$result_dir/worker_$comp_idx"
          fi
        else
          echo "pass" > "$result_dir/worker_$comp_idx" # no tests = pass
        fi
      ) &
      pids+=($!) # $! is the PID of the last background process

      worker=$((worker + 1))
    done

    # Wait for all workers in this wave to finish
    for pid in "${pids[@]}"; do
      wait "$pid" 2>/dev/null || true # wait for each worker (ignore exit code, check result files)
    done

    # Collect results from this wave
    worker=0
    while [ "$worker" -lt "$wave_size" ]; do
      comp_idx=$((wave_start + worker))
      component="${components[$comp_idx]}"
      result_file="$result_dir/worker_$comp_idx"
      if [ -f "$result_file" ] && [ "$(cat "$result_file")" = "pass" ]; then
        printf "  %s: ok\n" "$component"
        passed="$passed
  $component" # append component on a new indented line
      else
        printf "  %s: FAIL (see log/silent/worker-%d/%s.log)\n" "$component" "$((worker + 1))" "${component//\//-}"
        failed="$failed
  $component" # append component on a new indented line
      fi
      worker=$((worker + 1))
    done

    wave_start="$wave_end" # advance to next wave
  done

  # Clean up temp dir
  rm -rf "$result_dir"
fi

# Print pass/fail summary and exit with error if any component failed
print_results

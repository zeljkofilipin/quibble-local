#!/usr/bin/env bash
#
# Run shellcheck on all shell scripts in the repo.
#
# Usage: ./lint
#        ./lint --verbose
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/verbose # parse --verbose flag, set QUIBBLE_VERBOSE

# Check all scripts for shell scripting issues
shellcheck ci clean deep_clean deep_test dependencies fetch fresh_install gated help install lint prepare run_all run_selenium_tests selenium_tests_exist shellto test lib/debug_info lib/heartbeat lib/setup lib/ensure_config lib/inhibit_sleep lib/print_results lib/verbose

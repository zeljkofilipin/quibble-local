#!/usr/bin/env bash
#
# Find minimum dependencies for all gated repositories (or a single component).
# For each component: check if Selenium tests exist, check if it has optional dependencies,
# and run ./find_dependencies_minimal_greedy to find the minimum set.
# WARNING: Without arguments, this will take a very long time to run (50+ components).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./find_dependencies_minimal_gated
#        ./find_dependencies_minimal_gated extensions/Echo
#        VERBOSE=1 ./find_dependencies_minimal_gated
#        FAST=1 ./find_dependencies_minimal_gated
#        PARALLEL=1 ./find_dependencies_minimal_gated
#        PARALLEL=1 FAST=1 ./find_dependencies_minimal_gated
#
# FAST=1: Propagated to each find_dependencies_minimal_greedy child. The child runs fresh_install
#         once, saves state, then restores instead of re-running fresh_install for each combination.
# PARALLEL=N: Run N components in parallel (each in isolated ENVIRONMENT=N).
#             Use ./suggest_parallel to determine N for your machine.
#             Each worker needs ~2 CPU cores and ~2 GB of Docker memory.
#
# See also: ./find_dependencies_minimal_greedy for single-component usage.
#

# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking
. "$(dirname "$0")"/lib/pluralize # provides pluralize() for grammatical worker counts ("1 worker"/"2 workers")

# We invoke find_dependencies_minimal_greedy as a child via run_step, which pipes its output
# through `tee log/silent/<component>--find_dependencies_minimal_greedy.log`. The child script
# sources lib/batch_setup too, and its `rm -f log/silent/*.log` would unlink the very file tee
# is writing to — wiping the captured FOUND block before print_found_from_log can read it.
# Telling nested batch invocations to skip that cleanup keeps the file intact for the duration
# of the parent run. Our own batch_setup has already done the outer cleanup above.
export _QUIBBLE_NESTED_BATCH=1

parallel="${PARALLEL:-0}" # PARALLEL=N runs N components in parallel, each in its own src dir; unset/0 = sequential (default)

# --- Build list of gated components ---
. "$(dirname "$0")"/lib/build_component_list # sets components[] from $1 or ./list_gated

# --- Filter components: skip those without Selenium tests or without optional deps ---
filtered=() # array of components that need find_dependencies_minimal_greedy
for component in "${components[@]}"; do
  # Skip components without Selenium tests
  if ! ./selenium_tests_exist "$component"; then
    printf "skipped (no Selenium tests): %s\n" "$component"
    record_passed "$component"
    continue
  fi

  # Skip components without optional dependencies.
  # Capture output and check exit code: `< <(cmd)` swallows non-zero exits, which
  # would otherwise turn a real failure (e.g. missing ref/integration/config.git)
  # into "0 optional deps → skipped" and a misleading "All passed." at the end.
  if ! optional_output=$("$(dirname "$0")"/list_dependencies_optional "$component"); then
    echo "Error: failed to list optional dependencies for $component" >&2
    exit 1
  fi
  optional_count=0 # count optional dependencies
  if [ -n "$optional_output" ]; then # `<<<` on empty input yields one empty read; skip it
    while IFS= read -r dep; do
      [ -z "$dep" ] && continue # skip empty lines
      optional_count=$((optional_count + 1)) # count each optional dep
    done <<< "$optional_output"
  fi

  if [ "$optional_count" -eq 0 ]; then
    printf "skipped (no optional dependencies): %s\n" "$component"
    record_passed "$component"
    continue
  fi

  filtered+=("$component") # this component needs find_dependencies_minimal_greedy
done

if [ ${#filtered[@]} -eq 0 ]; then
  printf "\nNo components need find_dependencies_minimal_greedy.\n"
  print_results
  exit 0
fi

printf "\n%d %s to process.\n" "${#filtered[@]}" "$(pluralize "${#filtered[@]}" component)"

# Accumulate per-component "FOUND" blocks (extracted from each component's log) for
# a final summary printed before print_results. In silent mode the FOUND block is
# captured in the log file rather than shown live, so we surface it both inline
# (right after each component) and grouped (at the end) for easy scanning.
found_blocks="" # newline-separated FOUND blocks, one per processed component

# Print and accumulate a component's FOUND block from its log file.
# Usage: print_found_from_log COMPONENT LOG_FILE
print_found_from_log() {
  local _component="$1" # component name (kept for future use; unused for now)
  local _log_file="$2"  # path to the log file containing the FOUND block
  [ -z "$verbose" ] || return 0 # in verbose mode the inner script already printed the block live
  [ -f "$_log_file" ] || return 0 # no log file (e.g. component failed before reaching print_found)
  local _block
  _block=$(awk -f "$(dirname "$0")"/lib/extract_found_block.awk "$_log_file") # extract just the FOUND block
  [ -n "$_block" ] || return 0 # nothing to print (greedy failed before lib/print_found ran)
  printf "\n%s\n" "$_block" # print inline so progress feedback during the long run shows what was found
  found_blocks="${found_blocks}
${_block}
" # accumulate for the final summary (leading/trailing newline separates blocks)
  : "$_component" # silence shellcheck about unused parameter
}

if [ "$parallel" -lt 1 ]; then
  # --- Sequential mode ---
  for component in "${filtered[@]}"; do
    print_header "$component"

    # Run find_dependencies_minimal_greedy for this component
    if run_step "$component" ./find_dependencies_minimal_greedy "$component"; then
      record_passed "$component"
    fi
    printf " %s\n" "$(utc_timestamp)"

    # Surface the minimum-dependencies result captured in the log file (silent mode only).
    # Read from the same dir run_step wrote to ($QUIBBLE_LOG_DIR, set by lib/batch_setup) so a
    # per-worker log dir (generate_examples pool) still resolves the greedy log correctly.
    print_found_from_log "$component" "${QUIBBLE_LOG_DIR:-log/silent}/${component//\//-}--find_dependencies_minimal_greedy.log"
  done

else
  # --- Parallel mode (lib/run_pool: a dynamic slot pool, refilled as each component finishes) ---
  # Each component is tested independently by a child find_dependencies_minimal_greedy in an
  # isolated ENVIRONMENT=$slot (src_$slot/src_save_$slot). lib/run_pool keeps $parallel slots busy
  # and refills each the instant its item finishes. It prints its own "Parallel mode: N slots"
  # header; the hooks below add the per-dispatch and per-completion lines.

  # Per-component log + result files live here, keyed by COMPONENT (not slot): run_pool reuses each
  # slot id as items finish, so a slot-keyed path would be overwritten by the next item in that slot
  # before _pool_reap reads it. gated tests each component exactly once (filtered[] above), so the
  # component name is a collision-free key. Rooted at $QUIBBLE_LOG_DIR (like the sequential path)
  # so a nested run under generate_examples doesn't collide with a sibling pool worker.
  _gated_log_dir="${QUIBBLE_LOG_DIR:-log/silent}/parallel"
  rm -rf "$_gated_log_dir"   # drop stale logs/results from a prior run (batch_setup's startup
  mkdir -p "$_gated_log_dir" # *.log cleanup is non-recursive and won't reach this subdir)

  # lib/run_pool hook: worker body, run in a background subshell. $1 = stable 1..parallel slot id,
  # $2 = component. Must NOT install its own EXIT trap — run_pool sets one to touch its sentinel.
  _run_pool_worker() {
    local component="$2"
    local log_file="$_gated_log_dir/${component//\//-}.log"
    local result_file="$_gated_log_dir/${component//\//-}.result"
    export ENVIRONMENT="$1" # isolate src_$slot / src_save_$slot (lib/setup derives them from it)
    exec > "$log_file" 2>&1 # capture greedy's output (incl. its FOUND block) to the per-component log
    if ./find_dependencies_minimal_greedy "$component"; then
      echo "pass" > "$result_file"
    else
      echo "fail" > "$result_file"
    fi
  }

  # lib/run_pool hook: per-dispatch progress line. run_pool prints progress to stderr, so match it.
  # $1 = slot, $2 = component. Slot id equals ENVIRONMENT, shown so a user knows which src_N to read.
  _pool_worker_label() {
    printf "  Slot %d: %s (ENVIRONMENT=%d)\n" "$1" "$2" "$1" >&2
  }

  # lib/run_pool hook: per-completion. Runs in THIS shell (run_pool is sourced, not a subshell), so
  # it updates passed/failed and accumulates found_blocks directly, surfacing each result live, per
  # component (not batched at the end). $1 = slot (unused), $2 = component.
  _pool_reap() {
    local component="$2" result=""
    local log_file="$_gated_log_dir/${component//\//-}.log"
    local result_file="$_gated_log_dir/${component//\//-}.result"
    [ -f "$result_file" ] && result=$(cat "$result_file")
    if [ "$result" = "pass" ]; then
      printf "  %s: ok\n" "$component"
      passed="$passed
  $component" # append component on a new indented line
      print_found_from_log "$component" "$log_file" # surface (and accumulate) the FOUND block
    else
      printf "  %s: FAIL (see %s)\n" "$component" "$log_file"
      failed="$failed
  $component" # append component on a new indented line
    fi
  }

  items=("${filtered[@]}")          # lib/run_pool processes this ambient items[] across $parallel slots
  . "$(dirname "$0")"/lib/run_pool  # dispatch every component; the hooks above isolate + report each
fi

# Print all captured "FOUND" blocks together so the per-component results are
# easy to find at the end of the run without scrolling through dots and headers.
if [ -n "$found_blocks" ]; then
  printf "\n========================================\n"
  printf "= Minimum dependencies found\n"
  printf "========================================\n"
  printf "%s\n" "$found_blocks"
fi

# Print pass/fail summary and exit with error if any component failed
print_results

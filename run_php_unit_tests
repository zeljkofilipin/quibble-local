#!/usr/bin/env bash
#
# Run PHPUnit tests. Skips installation (assumes ./fresh_install or ./install has been run first).
#
# Usage: ./run_php_unit_tests
#        ./run_php_unit_tests extensions/Echo
#        ENVIRONMENT=0 ./run_php_unit_tests extensions/Echo
#        ./run_php_unit_tests extensions/Echo --filter testNotificationCount
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Parse optional component (extensions/X or skins/X) and extra arguments (e.g. --filter).
# Sets: component, zuul_project, extra_args
. "$(dirname "$0")"/lib/parse_component_args

# Decide how to run tests:
# - with extra args: pass them through to phpunit via --command
# - without extra args: use --run phpunit to run all tests
# ${#arr[@]} gets the number of elements in the array
if [ ${#extra_args[@]} -gt 0 ]; then
  # Run phpunit with specific arguments (e.g. --filter)
  quibble_args=(--command "php tests/phpunit/phpunit.php ${extra_args[*]}")
else
  # Run all PHPUnit tests
  quibble_args=(--run phpunit)
fi

. "$(dirname "$0")"/lib/setup # source shared setup (trace output in verbose mode only)
. "$(dirname "$0")"/lib/run_quibble_test # provides run_quibble_test function

# Run PHPUnit tests in the container
run_quibble_test "${quibble_args[@]}"

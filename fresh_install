#!/usr/bin/env bash
#
# Installs MediaWiki core (without running tests) and opens a shell.
# MediaWiki will be available at http://127.0.0.1:9413
# Runs ./prepare first if needed.
# WARNING: This will delete and recreate src/.
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble#Install_MediaWiki_Core
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib # source shared setup (enables trace output)

# Run prepare if bare repos haven't been cloned yet
if [ ! -d ref/mediawiki/core.git ]; then
  "$(dirname "$0")"/prepare
fi

# Clean src/ to ensure a fresh install
"$(dirname "$0")"/clean

# Ensure working directories exist with proper permissions for the container user.
# Docker creates missing mount dirs as root; chmod may fail if they're already root-owned.
mkdir -p cache log src
# chmod may fail if dirs are already root-owned, so fall back to Docker as root
chmod 777 cache log src 2>/dev/null || \
  docker run --rm \
    --entrypoint bash \
    --user root \
    -v "$(pwd)"/cache:/cache \
    -v "$(pwd)"/log:/workspace/log \
    -v "$(pwd)"/src:/workspace/src \
    "$QUIBBLE_IMAGE" \
    -c 'chmod 777 /cache /workspace/log /workspace/src'

# Install MediaWiki and open a shell (--command true = install only, no tests)
docker run -it --rm \
  --entrypoint=quibble-with-supervisord \
  -p 9413:9413 \
  -v "$(pwd)"/cache:/cache \
  -v "$(pwd)"/log:/workspace/log \
  -v "$(pwd)"/ref:/srv/git:ro \
  -v "$(pwd)"/src:/workspace/src \
  "$QUIBBLE_IMAGE" \
  --command true

#!/usr/bin/env bash
#
# Installs MediaWiki core (without running tests).
# Run ./shellto afterwards to open a shell with MediaWiki running.
# Runs ./prepare first if needed.
# WARNING: This will delete and recreate src/.
#
# Usage: ./fresh_install
#        ENVIRONMENT=0 ./fresh_install
#        VERBOSE=1 ./fresh_install
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble#Install_MediaWiki_Core
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/setup # source shared setup (trace output in verbose mode only)

# Run prepare if bare repos haven't been cloned yet
if [ ! -d ref/mediawiki/core.git ]; then
  "$(dirname "$0")"/prepare
fi

# Clean src/ to ensure a fresh install
"$(dirname "$0")"/clean

# Ensure working directories exist with proper permissions for the container user.
# Docker creates missing mount dirs as root; chmod may fail if they're already root-owned.
# Uses QUIBBLE_SRC from lib/setup (default "src", overridden for parallel workers).
mkdir -p cache log "$QUIBBLE_SRC"
# chmod 777: container runs as a different user, so dirs must be world-writable.
# 2>/dev/null: suppress errors if dirs are already root-owned.
# ||: if chmod fails, fall back to Docker as root to set permissions.
# --rm: remove container on exit
# --entrypoint bash: override default entrypoint to run a shell command
# --user root: run as root to have permission to chmod
chmod 777 cache log "$QUIBBLE_SRC" 2>/dev/null || \
  docker run --rm \
    --entrypoint bash \
    --user root \
    -v "$QUIBBLE_DIR"/cache:/cache \
    -v "$QUIBBLE_DIR"/log:/workspace/log \
    -v "$QUIBBLE_DIR"/"$QUIBBLE_SRC":/workspace/src \
    "$QUIBBLE_IMAGE" \
    -c 'chmod 777 /cache /workspace/log /workspace/src' # set permissions inside the container

# Install MediaWiki and open a shell
# "${QUIBBLE_DOCKER_FLAGS[@]}": -it in verbose mode, -i in silent mode (set by lib/setup)
# --rm: remove container on exit
# --entrypoint=quibble-with-supervisord: use Quibble's supervisord entrypoint
# "${QUIBBLE_VOLUMES[@]}": mount shared volumes (cache, log, ref, src)
# --command true: install only, don't run tests ("true" exits immediately)
docker run "${QUIBBLE_DOCKER_FLAGS[@]}" --rm \
  --entrypoint=quibble-with-supervisord \
  "${QUIBBLE_VOLUMES[@]}" \
  "$QUIBBLE_IMAGE" \
  --command true

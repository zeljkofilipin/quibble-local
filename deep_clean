#!/usr/bin/env bash
#
# Remove everything quibble-local created, leaving only the git repo itself.
# This removes cache/, log/, src/, ref/ and the Docker image.
# WARNING: This will delete everything including bare repos (slow to re-clone).
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/setup # source shared setup (enables trace output)

# Use Docker (as root) to remove files owned by the container user.
# Check if the Docker image exists (suppress all output)
if docker image inspect "$QUIBBLE_IMAGE" &>/dev/null; then
  docker run --rm \
    --entrypoint bash \
    --user root \
    -v "$(pwd)"/cache:/cache \
    -v "$(pwd)"/log:/workspace/log \
    -v "$(pwd)"/src:/workspace/src \
    -v "$(pwd)"/ref:/workspace/ref \
    "$QUIBBLE_IMAGE" \
    -c 'find /cache /workspace/log /workspace/src /workspace/ref -mindepth 1 -delete'
fi

# Remove the now-empty directories from the host
rm -rf cache log src ref

# Remove the Docker image (ignore errors if already removed)
docker rmi "$QUIBBLE_IMAGE" 2>/dev/null || true

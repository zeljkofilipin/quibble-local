#!/usr/bin/env bash
#
# Remove everything quibble-local created, leaving only the git repo itself.
# This removes cache/, log/, src/, src_save/, ref/ and the Docker image.
# WARNING: This will delete everything including bare repos (slow to re-clone).
#
# Usage: ./deep_clean
#        VERBOSE=1 ./deep_clean
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/setup # source shared setup (trace output in verbose mode only)

# Use Docker (as root) to remove files owned by the container user.
# &>/dev/null: suppress both stdout and stderr from the inspect command
if docker image inspect "$QUIBBLE_IMAGE" &>/dev/null; then # check if the Docker image exists locally
  # --rm: remove container on exit
  # --entrypoint bash: override default entrypoint to run a shell command
  # --user root: run as root to have permission to delete all files
  # -v: mount each directory so we can delete its contents from inside the container
  docker run --rm \
    --entrypoint bash \
    --user root \
    -v "$QUIBBLE_DIR"/cache:/cache \
    -v "$QUIBBLE_DIR"/log:/workspace/log \
    -v "$QUIBBLE_DIR"/src:/workspace/src \
    -v "$QUIBBLE_DIR"/src_save:/workspace/src_save \
    -v "$QUIBBLE_DIR"/ref:/workspace/ref \
    "$QUIBBLE_IMAGE" \
    -c 'find /cache /workspace/log /workspace/src /workspace/src_save /workspace/ref -mindepth 1 -delete' # delete contents but not mount points
fi

# Remove the now-empty directories from the host
rm -rf cache log src src_save ref

# Remove the Docker image (ignore errors if already removed)
docker rmi "$QUIBBLE_IMAGE" 2>/dev/null || true

#!/usr/bin/env bash
#
# Install an extension or skin and open a shell.
# MediaWiki will be available at http://127.0.0.1:9413
# Assumes ./fresh_install has been run first.
#
# Usage: ./install extensions/Echo
#        ./install skins/MinervaNeue
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble#Install_MediaWiki_Core_and_an_Extension
#
set -euo pipefail

if [ $# -eq 0 ]; then
  echo "Usage: ./install extensions/EXTENSION or ./install skins/SKIN"
  exit 1
fi

component="$1"
repo="mediawiki/${component}"
ref_dir="ref/${repo}.git"

. "$(dirname "$0")"/lib

# Clone bare repo if not already present
if [ ! -d "$ref_dir" ]; then
  mkdir -p "$(dirname "$ref_dir")"
  git clone --bare "https://gerrit.wikimedia.org/r/${repo}" "$ref_dir"
fi

# Clone integration/config for dependency info
config_ref_dir="ref/integration/config.git"
if [ ! -d "$config_ref_dir" ]; then
  mkdir -p "$(dirname "$config_ref_dir")"
  git clone --bare "https://gerrit.wikimedia.org/r/integration/config" "$config_ref_dir"
fi
config_src_dir="src/config"
if [ ! -d "$config_src_dir" ]; then
  git clone "$config_ref_dir" "$config_src_dir"
fi

# Build list of dependency repos from zuul/dependencies.yaml
# Disable trace output while processing dependencies (too noisy)
set +x
deps=()
while IFS= read -r dep_name; do
  if [[ "$dep_name" == skins/* ]]; then
    dep_repo="mediawiki/${dep_name}"
  else
    dep_repo="mediawiki/extensions/${dep_name}"
  fi
  # Clone bare repo for dependency if not already present
  dep_ref_dir="ref/${dep_repo}.git"
  if [ ! -d "$dep_ref_dir" ]; then
    echo "Cloning dependency: ${dep_name}"
    mkdir -p "$(dirname "$dep_ref_dir")"
    git clone --bare "https://gerrit.wikimedia.org/r/${dep_repo}" "$dep_ref_dir"
  fi
  deps+=("$dep_repo")
done < <("$(dirname "$0")"/dependencies "$component")
# Re-enable trace output
set -x

# Install extension/skin with its dependencies
# --resolve-requires: let Quibble resolve and install dependencies
# --command true: install only, no tests
# "${deps[@]}": list of dependency repos to clone
docker run -it --rm \
  --entrypoint=quibble-with-supervisord \
  -p 9413:9413 \
  -v "$(pwd)"/cache:/cache \
  -v "$(pwd)"/log:/workspace/log \
  -v "$(pwd)"/ref:/srv/git:ro \
  -v "$(pwd)"/src:/workspace/src \
  -e ZUUL_PROJECT="${repo}" \
  docker-registry.wikimedia.org/releng/quibble-bullseye-php83:latest \
  --resolve-requires \
  --command true \
  "${deps[@]}"

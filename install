#!/usr/bin/env bash
#
# Installs an extension or skin (and its dependencies) into an existing MediaWiki core.
# Skips core installation (assumes ./fresh_install has already installed core).
# Run ./shellto afterwards to open a shell with MediaWiki running.
#
# Usage: ./install extensions/Echo
#        ./install skins/MinervaNeue
#        VERBOSE=1 ./install extensions/Echo
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble#Install_MediaWiki_Core_and_an_Extension
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Show usage if no argument provided
if [ $# -eq 0 ]; then # $# is the number of arguments
  echo "Usage: ./install extensions/EXTENSION or ./install skins/SKIN"
  exit 1
fi

# Build paths from the component argument (e.g. "extensions/Echo")
component="$1"
repo="mediawiki/${component}"       # e.g. "mediawiki/extensions/Echo"
ref_dir="ref/${repo}.git"           # e.g. "ref/mediawiki/extensions/Echo.git"

. "$(dirname "$0")"/lib/setup # source shared setup (trace output in verbose mode only)

# Clone bare repo for the extension/skin if not already present
if [ ! -d "$ref_dir" ]; then
  mkdir -p "$(dirname "$ref_dir")"  # create parent directories
  git clone --bare "https://gerrit.wikimedia.org/r/${repo}" "$ref_dir"
fi

# Clone bare repo for integration/config if not already present
if [ ! -d "ref/integration/config.git" ]; then
  mkdir -p ref/integration # create parent directories
  git clone --bare "https://gerrit.wikimedia.org/r/integration/config" "ref/integration/config.git"
fi
# Ensure integration/config working copy exists (needed by ./dependencies)
. "$(dirname "$0")"/lib/ensure_config

# Build list of dependency repos.
# If QUIBBLE_DEPS is set (even if empty), use that instead of zuul/dependencies.yaml.
# This allows callers like ./minimal_dependencies to test with a subset of dependencies.
set +x # disable trace output while processing dependencies (too noisy)
deps=() # array to collect dependency repo paths
# Read each dependency name from the dependency source.
# IFS= prevents trimming whitespace; -r prevents backslash interpretation.
# < <(...) is process substitution: feeds dependency names as stdin.
while IFS= read -r dep_name; do
  [ -z "$dep_name" ] && continue # skip empty lines (e.g. when QUIBBLE_DEPS is empty)
  # Skins use "mediawiki/skins/Name", extensions use "mediawiki/extensions/Name"
  if [[ "$dep_name" == skins/* ]]; then
    dep_repo="mediawiki/${dep_name}"
  else
    dep_repo="mediawiki/extensions/${dep_name}"
  fi
  # Clone bare repo for dependency if not already present
  dep_ref_dir="ref/${dep_repo}.git"
  if [ ! -d "$dep_ref_dir" ]; then
    echo "Cloning dependency: ${dep_name}"
    mkdir -p "$(dirname "$dep_ref_dir")" # create parent directories
    git clone --bare "https://gerrit.wikimedia.org/r/${dep_repo}" "$dep_ref_dir"
  fi
  deps+=("$dep_repo") # add to the dependencies array; += appends to bash arrays
done < <(
  # ${QUIBBLE_DEPS+x} is set if QUIBBLE_DEPS is defined (even if empty string).
  # This distinguishes "not set" (use dependencies.yaml) from "set to empty" (no deps).
  if [ -n "${QUIBBLE_DEPS+x}" ]; then
    # shellcheck disable=SC2086 # intentional word splitting: space-separated deps → one per line
    printf '%s\n' ${QUIBBLE_DEPS}
  else
    "$(dirname "$0")"/dependencies "$component" # read from zuul/dependencies.yaml
  fi
)
# Re-enable trace output only in verbose mode (in silent mode, set -x was never enabled)
if [ "${VERBOSE:-}" = "1" ]; then
  set -x # re-enable trace output
fi

# Install extension/skin with its dependencies
# "${QUIBBLE_DOCKER_FLAGS[@]}": -it in verbose mode, -i in silent mode (set by lib/setup)
# --rm: remove container on exit
# --entrypoint=quibble-with-supervisord: use Quibble's supervisord entrypoint
# -p 9413:9413: expose MediaWiki port from container to host
# "${QUIBBLE_VOLUMES[@]}": mount shared volumes (cache, log, ref, src)
# -e ZUUL_PROJECT: tell Quibble which extension/skin is the main project
# --resolve-requires: let Quibble resolve and install PHP/extension dependencies
# --command true: install only, don't run tests
# ${deps[@]+"..."}: list of dependency repos to clone; ${arr[@]+"..."} is safe for empty arrays in bash 3.2
docker run "${QUIBBLE_DOCKER_FLAGS[@]}" --rm \
  --entrypoint=quibble-with-supervisord \
  -p 9413:9413 \
  "${QUIBBLE_VOLUMES[@]}" \
  -e ZUUL_PROJECT="${repo}" \
  "$QUIBBLE_IMAGE" \
  --resolve-requires \
  --command true \
  ${deps[@]+"${deps[@]}"}

#!/usr/bin/env bash
#
# Install an extension or skin and open a shell.
# MediaWiki will be available at http://127.0.0.1:9413
# Assumes ./fresh_install has been run first.
#
# Usage: ./install extensions/Echo
#        ./install skins/MinervaNeue
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble#Install_MediaWiki_Core_and_an_Extension
#
set -euo pipefail

# Display the command with delimiters, then execute it.
run() {
  local max_len
  max_len=$(echo "$1" | awk '{ if (length > max) max = length } END { print max }')
  local delimiter
  delimiter=$(printf '%*s' "$max_len" '' | tr ' ' '-')
  echo "$delimiter
install is running this command:
$delimiter
$1
$delimiter"
  eval "$1"
}

if [ $# -eq 0 ]; then
  echo "Usage: ./install extensions/EXTENSION or ./install skins/SKIN"
  exit 1
fi

component="$1"
repo="mediawiki/${component}"
ref_dir="ref/${repo}.git"

# Clone bare repo if not already present
if [ ! -d "$ref_dir" ]; then
  mkdir -p "$(dirname "$ref_dir")"
  run "git clone --bare https://gerrit.wikimedia.org/r/${repo} $ref_dir"
fi

run "docker run -it --rm
  --entrypoint=quibble-with-supervisord
  -p 9413:9413
  -v $(pwd)/cache:/cache
  -v $(pwd)/log:/workspace/log
  -v $(pwd)/ref:/srv/git:ro
  -v $(pwd)/src:/workspace/src
  -e ZUUL_PROJECT=${repo}
  docker-registry.wikimedia.org/releng/quibble-bullseye-php83:latest
  --skip-zuul
  --skip-deps
  --shell"

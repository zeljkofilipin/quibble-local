#!/usr/bin/env bash
#
# Installs an extension or skin (and its dependencies) into an existing MediaWiki core and opens a shell.
# Skips core installation (assumes ./fresh_install has already installed core).
# MediaWiki will be available at http://127.0.0.1:9413
#
# Usage: ./install extensions/Echo
#        ./install skins/MinervaNeue
#
# See: https://www.mediawiki.org/wiki/Selenium/How-to/Run_tests_targeting_Quibble#Install_MediaWiki_Core_and_an_Extension
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Show usage if no argument provided
if [ $# -eq 0 ]; then
  echo "Usage: ./install extensions/EXTENSION or ./install skins/SKIN"
  exit 1
fi

# Build paths from the component argument (e.g. "extensions/Echo")
component="$1"
repo="mediawiki/${component}"       # e.g. "mediawiki/extensions/Echo"
ref_dir="ref/${repo}.git"           # e.g. "ref/mediawiki/extensions/Echo.git"

. "$(dirname "$0")"/lib # source shared setup (enables trace output)

# Clone bare repo for the extension/skin if not already present
if [ ! -d "$ref_dir" ]; then
  mkdir -p "$(dirname "$ref_dir")"  # create parent directories
  git clone --bare "https://gerrit.wikimedia.org/r/${repo}" "$ref_dir"
fi

# Clone bare repo for integration/config if not already present
if [ ! -d "ref/integration/config.git" ]; then
  mkdir -p ref/integration # create parent directories
  git clone --bare "https://gerrit.wikimedia.org/r/integration/config" "ref/integration/config.git"
fi
# Ensure integration/config working copy exists (needed by ./dependencies)
. "$(dirname "$0")"/ensure_config

# Build list of dependency repos from zuul/dependencies.yaml
# Disable trace output while processing dependencies (too noisy)
set +x
deps=() # array to collect dependency repo paths
# Read each dependency name from the ./dependencies script output
while IFS= read -r dep_name; do
  # Skins use "mediawiki/skins/Name", extensions use "mediawiki/extensions/Name"
  if [[ "$dep_name" == skins/* ]]; then
    dep_repo="mediawiki/${dep_name}"
  else
    dep_repo="mediawiki/extensions/${dep_name}"
  fi
  # Clone bare repo for dependency if not already present
  dep_ref_dir="ref/${dep_repo}.git"
  if [ ! -d "$dep_ref_dir" ]; then
    echo "Cloning dependency: ${dep_name}"
    mkdir -p "$(dirname "$dep_ref_dir")" # create parent directories
    git clone --bare "https://gerrit.wikimedia.org/r/${dep_repo}" "$dep_ref_dir"
  fi
  deps+=("$dep_repo") # add to the dependencies array
done < <("$(dirname "$0")"/dependencies "$component") # feed dependency names from ./dependencies
# Re-enable trace output
set -x

# Install extension/skin with its dependencies
# -e ZUUL_PROJECT: tell Quibble which extension/skin is the main project
# --resolve-requires: let Quibble resolve and install PHP/extension dependencies
# --command true: install only, no tests
# "${deps[@]}": list of dependency repos to clone
docker run -it --rm \
  --entrypoint=quibble-with-supervisord \
  -p 9413:9413 \
  "${QUIBBLE_VOLUMES[@]}" \
  -e ZUUL_PROJECT="${repo}" \
  "$QUIBBLE_IMAGE" \
  --resolve-requires \
  --command true \
  "${deps[@]}"

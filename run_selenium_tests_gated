#!/usr/bin/env bash
#
# Install all gated extensions and skins into a single MediaWiki, then run all Selenium tests.
# Unlike ./run_selenium_tests_all_gated (which does ./fresh_install per component), this installs
# everything together into one src/.
# Uses ./install_all_gated for installation, then runs Selenium tests for each component.
# WARNING: This will take a long time to run (50+ components).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./run_selenium_tests_gated
#        VERBOSE=1 ./run_selenium_tests_gated
#

# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking

# --- Install core and all gated repositories ---
print_header "install_all_gated"
if ! run_step install ./install_all_gated; then # install core + all gated; abort if this fails
  printf " %s\n" "$(utc_timestamp)"
  print_results
  exit 1
fi
printf " %s\n" "$(utc_timestamp)" # print UTC timestamp after install

# --- Build list of gated components for test phase ---
components=() # array of gated components
while IFS= read -r component; do
  components+=("$component")
done < <("$(dirname "$0")"/gated)

# --- Run Selenium tests for all installed components ---
# Core first
print_header "core(selenium)"
if ./selenium_tests_exist; then # check if core has Selenium tests
  run_step core ./run_selenium_tests
fi
record_passed "core"
printf " %s\n" "$(utc_timestamp)"

# Then each gated component
for component in "${components[@]}"; do
  print_header "$component(selenium)"
  if ./selenium_tests_exist "$component"; then # check if this component has Selenium tests
    run_step "$component" ./run_selenium_tests "$component"
  fi
  record_passed "$component"
  printf " %s\n" "$(utc_timestamp)"
done

# Print pass/fail summary and exit with error if any component failed
print_results

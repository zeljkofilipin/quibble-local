#!/usr/bin/env bash
#
# Regenerate example output files in examples/ by iterating each project-root script's # Usage: block.
# Iteration 1: runs only the FIRST Usage line per script (the simplest invocation, after Commit 1's reorder).
# Filenames are derived from the command (see lib/cmd_to_filename).
# Useful for refreshing examples/ in bulk after script renames or behavior changes.
#
# Usage: ./generate_examples
#        DRY_RUN=1 ./generate_examples
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/duration_trap # print elapsed time on exit
. "$(dirname "$0")"/lib/cmd_to_filename # provides cmd_to_filename function

# Switch to the script's directory (project root) so relative paths and ./scripts work
# regardless of where this is invoked from. $0 may be relative or absolute; dirname handles both.
cd "$(dirname "$0")"

# Iterate project-root files. Auto-discover scripts the same way ./lint and ./help do:
# the first line must be a bash shebang or a shellcheck directive.
for script in *; do
  [ -f "$script" ] || continue                                      # skip directories
  [ -x "$script" ] || continue                                      # skip non-executable files
  # Avoid recursion: don't try to regenerate examples for ourselves or our single-file helper.
  case "$script" in generate_examples|generate_example) continue ;; esac
  read -r first_line < "$script" || continue                        # read first line; skip on read failure
  # Match scripts the same way auto-discovery does elsewhere in this repo.
  case "$first_line" in
    '#!/usr/bin/env bash'|'# shellcheck'*) ;;
    *) continue ;;
  esac
  # Take only the first Usage line (iteration 1).
  # `head -n 1` may close the pipe early; awk's SIGPIPE is harmless here.
  cmd="$(awk -f lib/parse_usage.awk "$script" | head -n 1)"
  if [ -z "$cmd" ]; then
    echo "Skipping $script: no # Usage: block" >&2 # >&2 prints to stderr
    continue
  fi
  file="$(cmd_to_filename "$cmd")"                                  # derive examples/*.txt filename from the command
  if [ -n "${DRY_RUN:-}" ]; then                                    # ${VAR:-} is "" when VAR is unset (works under set -u)
    echo "Would generate $file from: $cmd"                          # DRY_RUN mode: print what would happen
  else
    ./generate_example "$file" "$cmd"                               # actually run the command and capture output
  fi
done

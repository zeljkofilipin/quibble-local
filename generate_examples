#!/usr/bin/env bash
#
# Regenerate example output files in examples/ by iterating each project-root script's # Usage: block.
# Runs every Usage line of every script; filenames are derived from the command (see lib/cmd_to_filename).
# Useful for refreshing examples/ in bulk after script renames or behavior changes.
#
# Usage: ./generate_examples
#        DRY_RUN=1 ./generate_examples
#        FAST=1 ./generate_examples
#
# DRY_RUN and FAST do different things:
#   DRY_RUN=1 ./generate_examples  — outer-level preview. Prints "Would generate ..." for each
#                                    Usage line. No files written, no inner scripts run.
#   FAST=1 ./generate_examples     — actually generate every file, but prepend DRY_RUN=1 to
#                                    each Usage command so Quibble short-circuits. Inner scripts
#                                    that honor DRY_RUN (install, fresh_install, run_php_unit_tests,
#                                    run_selenium_tests, and batch scripts that propagate the env
#                                    var to them) finish in seconds instead of minutes. Other
#                                    scripts ignore the unused env var.
# The two can be combined: DRY_RUN=1 FAST=1 previews the FAST-mode command list.
# Use FAST=1 to iterate on generate_examples itself or to validate the pipeline end-to-end.
# Do NOT commit examples/*.txt produced under FAST=1 — they do not reflect real script behavior.
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/duration_trap # print elapsed time on exit
. "$(dirname "$0")"/lib/cmd_to_filename # provides cmd_to_filename function
. "$(dirname "$0")"/lib/inhibit_sleep # prevent the machine from suspending during the long run

# FAST mode: warn loudly on stderr so the user can't miss it when piping/teeing.
if [ -n "${FAST:-}" ]; then
  echo "generate_examples: FAST mode enabled — do not commit the resulting examples/" >&2
fi

# Switch to the script's directory (project root) so relative paths and ./scripts work
# regardless of where this is invoked from. $0 may be relative or absolute; dirname handles both.
cd "$(dirname "$0")"

# Track filenames already generated so two distinct Usage lines don't silently overwrite
# each other. Bash 3.2 has no associative arrays; use a delimited string.
seen="|"

# Iterate project-root files. Auto-discover scripts the same way ./lint and ./help do:
# the first line must be a bash shebang or a shellcheck directive.
for script in *; do
  [ -f "$script" ] || continue                                      # skip directories
  [ -x "$script" ] || continue                                      # skip non-executable files
  # Avoid recursion: don't try to regenerate examples for ourselves or our single-file helper.
  case "$script" in generate_examples|generate_example) continue ;; esac
  read -r first_line < "$script" || continue                        # read first line; skip on read failure
  # Match scripts the same way auto-discovery does elsewhere in this repo.
  case "$first_line" in
    '#!/usr/bin/env bash'|'# shellcheck'*) ;;
    *) continue ;;
  esac
  # Capture every Usage line of this script.
  usage_block="$(awk -f lib/parse_usage.awk "$script")"
  if [ -z "$usage_block" ]; then
    echo "Skipping $script: no # Usage: block" >&2 # >&2 prints to stderr
    continue
  fi
  # Iterate each Usage line. `<<<` feeds the captured block to the loop; the loop
  # runs in the current shell so `set -e` and exits behave normally.
  while IFS= read -r cmd; do
    [ -n "$cmd" ] || continue                                       # skip blank lines (defensive)
    file="$(cmd_to_filename "$cmd")"                                # derive examples/*.txt filename from the command
    case "$seen" in
      *"|$file|"*)                                                  # already generated this filename earlier
        echo "Skipping $cmd: $file already generated (filename collision)" >&2
        continue
        ;;
    esac
    seen="${seen}${file}|"                                          # remember we've claimed this filename
    # In FAST mode, prepend DRY_RUN=1 to the command so Quibble-running scripts short-circuit.
    # The filename was derived from the ORIGINAL command above, so output goes to the same
    # path as a real run. Skip the prepend if the command already sets DRY_RUN= itself.
    run_cmd="$cmd"
    if [ -n "${FAST:-}" ]; then
      case "$cmd" in
        *DRY_RUN=*) ;;                                              # already explicit; leave alone
        *) run_cmd="DRY_RUN=1 $cmd" ;;
      esac
    fi
    if [ -n "${DRY_RUN:-}" ]; then                                  # ${VAR:-} is "" when VAR is unset (works under set -u)
      echo "Would generate $file from: $run_cmd"                    # DRY_RUN mode: print what would happen
    else
      ./generate_example "$file" "$run_cmd"                         # actually run the command and capture output
    fi
  done <<< "$usage_block"
done

#!/usr/bin/env bash
#
# Generate an example output file by running a command and capturing its output.
# Used to refresh the example .txt files in examples/ that show typical command output.
# Writes "$ <command>" header followed by a blank line and the captured output (stdout+stderr).
# The captured command is allowed to fail (its exit status is not propagated) so that
# usage-on-failure outputs (e.g. ./install with no args) can also be captured.
#
# Usage: ./generate_example examples/help.txt './help'
#        ./generate_example examples/install.txt './install'
#
set -euo pipefail # exit on error, undefined vars, or pipe failures
. "$(dirname "$0")"/lib/duration_trap # print elapsed time on exit (no debug_info: this is a short utility, no VERBOSE mode)

# Require exactly two arguments: output file path and the command to run as a single string
if [ "$#" -ne 2 ]; then
  echo "Usage: ./generate_example <output_file> '<command>'" >&2 # >&2 prints to stderr
  exit 1
fi

file="$1" # path of the example file to write (e.g. examples/help.txt)
cmd="$2"  # command to run, as a single string (e.g. './help install')

# Switch to the script's directory (project root) so relative paths and ./scripts work
# regardless of where this is invoked from. $0 may be relative or absolute; dirname handles both.
cd "$(dirname "$0")"

echo "Generating $file..." # progress message so the user sees what's being generated

# Write the "$ <cmd>" header followed by a blank line. Truncates the file if it existed.
printf '$ %s\n\n' "$cmd" > "$file"

# Run the command and append stdout+stderr DIRECTLY to the file (no intermediate pipe).
# Direct redirection preserves the line-by-line streaming UX so a user running
# `tail -f examples/<file>.txt` against a long capture sees progress in real time.
# An earlier version piped through `awk` for path scrubbing, but introducing a pipe
# makes any libc-using child in the captured pipeline switch from block-buffered to
# fully-buffered output (the writer side sees "stdout is a pipe", not a regular file),
# so captures stalled until ~8KB chunks filled. Path scrubbing now happens in a
# second pass once the capture completes, below.
# eval is needed because $cmd is a single string with arguments and quoting baked in.
# || true lets the script continue when the captured command exits non-zero (common
# for usage-on-failure outputs); without it, set -e would abort the post-capture
# scrubbing pass and the (no output) marker check below.
# Subshell with exported _QUIBBLE_FORCE_TERMINAL=1 makes the captured script act as if
# its stdout were a terminal (see lib/silent_output, lib/duration_trap, lib/debug_info)
# so examples/*.txt contains the silent-mode UX a user would see, not the piped-stdout
# verbose passthrough. The subshell scopes the export so it does not leak.
(export _QUIBBLE_FORCE_TERMINAL=1; eval "$cmd") >> "$file" 2>&1 || true

# Scrub the project's absolute path to "$PWD" once the capture is complete so the
# saved file is machine-independent (see lib/scrub_pwd.awk for the rationale). Running
# awk on the finished file rather than mid-stream keeps `tail -f` working above.
# `awk file > file.tmp && mv file.tmp file` is the standard pattern for in-place
# awk edits — awk can't safely write to the same file it's reading.
awk -v pwd="$PWD" -f lib/scrub_pwd.awk "$file" > "$file".tmp && mv "$file".tmp "$file"

# Strip ANSI CSI escape sequences (color codes, cursor moves) emitted by tools inside
# the Quibble image (colorlog, composer, npm). They appear in the captured file as
# literal "[33m..." etc., which is noise when reading examples/*.txt or diffing them
# (see lib/scrub_ansi.awk for the rationale). Same in-place awk pattern as above.
awk -f lib/scrub_ansi.awk "$file" > "$file".tmp && mv "$file".tmp "$file"

# If the captured body is empty (file is just the header + blank line), append an explicit
# "(no output)" marker. Without it, the file is indistinguishable from a broken or aborted
# capture — uninformative as documentation. Commands that exit silently on success (./lint),
# cleanup commands with nothing to do (./remove on a clean tree), and similar legitimate
# cases all land here. `tail -n +3` skips the header line and its trailing blank, returning
# everything from line 3 onward; `$(...)` strips trailing newlines so a stray "\n" from the
# eval is still treated as empty.
if [ -z "$(tail -n +3 "$file")" ]; then
  printf '(no output)\n' >> "$file"
fi

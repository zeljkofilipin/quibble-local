#!/usr/bin/env bash
#
# Run Selenium tests for core and all gated repositories (or a single component).
# For each component: fresh_install, install (if not core),
# check if Selenium tests exist, and run them.
# WARNING: Without arguments, this will take a very long time to run (50+ components).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./run_selenium_tests_all_gated
#        ./run_selenium_tests_all_gated extensions/Echo
#        VERBOSE=1 ./run_selenium_tests_all_gated
#        FAST=1 ./run_selenium_tests_all_gated
#        PARALLEL=$(./suggest_parallel) ./run_selenium_tests_all_gated
#        PARALLEL=4 FAST=1 ./run_selenium_tests_all_gated
# FAST=1: Runs fresh_install once, saves state, then restores instead of re-running fresh_install.
# PARALLEL=N: Run N components in parallel (each in isolated src_worker_$i/ directory).
#             Use ./suggest_parallel to determine N for your machine.
#
# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking
fast="${FAST:-}" # FAST=1 saves fresh_install state and restores instead of re-running
parallel="${PARALLEL:-1}" # PARALLEL=N runs N components in parallel (default 1 = sequential)

# --- Core ---
print_header "core"
if run_step core ./fresh_install; then # install core; skip remaining steps if this fails
  # Save state after first fresh_install for fast mode
  if [ -n "$fast" ]; then
    run_step core ./save
  fi
  if ./selenium_tests_exist; then # check if core has Selenium tests
    run_step core ./run_selenium_tests # run core Selenium tests
  fi
  record_passed "core"
fi
printf " %s\n" "$(utc_timestamp)" # print UTC timestamp after core

# --- Build list of gated components ---
. "$(dirname "$0")"/lib/build_component_list # sets components[] from $1 or ./list_gated

if [ "$parallel" -le 1 ]; then
  # --- Sequential mode ---
  # IFS= preserves whitespace in component names; -r prevents backslash interpretation.
  # <&3 reads from file descriptor 3 instead of stdin, because docker's -it flag needs stdin.
  # 3< <(...) is process substitution: connects array output to fd 3.
  while IFS= read -r component <&3; do
    print_header "$component"
    # Restore from saved state in fast mode, or run fresh_install
    if [ -n "$fast" ] && [ -d "${QUIBBLE_SAVE:-src_save}" ]; then
      core_ok=false; run_step "$component" ./restore && core_ok=true
    else
      core_ok=false; run_step "$component" ./fresh_install && core_ok=true
    fi
    if [ "$core_ok" = true ]; then # skip remaining steps if core setup fails
      if run_step "$component" ./install "$component"; then # install extension/skin; skip tests if this fails
        if ./selenium_tests_exist "$component"; then # check if this component has Selenium tests
          run_step "$component" ./run_selenium_tests "$component" # run Selenium tests
        fi
      fi
    fi
    record_passed "$component"
    printf " %s\n" "$(utc_timestamp)" # print UTC timestamp after component
  done 3< <(printf '%s\n' "${components[@]}")

else
  # --- Parallel mode ---
  printf "\nParallel mode: %d workers\n" "$parallel"

  if [ -n "$fast" ] && [ ! -d "${QUIBBLE_SAVE:-src_save}" ]; then
    # Ensure save directory exists for workers to restore from (core was already installed above)
    printf "\nError: FAST mode requires %s/ (run ./save first or let core step create it).\n" "${QUIBBLE_SAVE:-src_save}"
    exit 1
  fi

  # Define worker function: restore/fresh_install → install → run_selenium_tests.
  # Runs inside a background subshell via lib/run_waves.
  # $1: result_file path to write pass/fail
  # $2: component name (e.g. "extensions/Echo")
  _run_worker() {
    local result_file="$1" # path to write "pass" or "fail"
    local component="$2"   # e.g. "extensions/Echo"

    # Common worker setup: set environment, redirect output, restore/fresh_install
    . lib/worker_init

    # Install extension/skin
    if ! ./install "$component"; then
      echo "fail" > "$result_file"
      exit 1
    fi

    # Run Selenium tests if they exist
    if ./selenium_tests_exist "$component"; then
      if ./run_selenium_tests "$component"; then
        echo "pass" > "$result_file"
      else
        echo "fail" > "$result_file"
      fi
    else
      echo "pass" > "$result_file" # no tests = pass
    fi
  }

  # Define result collector: record pass/fail for each component.
  # $1: component name
  # $2: result string (pass/fail/empty)
  # $3: worker number (1-based)
  _collect_result() {
    local component="$1" result="$2" worker_num="$3"
    if [ "$result" = "pass" ]; then
      printf "  %s: ok\n" "$component"
      passed="$passed
  $component" # append component on a new indented line
    else
      printf "  %s: FAIL (see log/silent/worker-%d/%s.log)\n" "$component" "$worker_num" "${component//\//-}"
      failed="$failed
  $component" # append component on a new indented line
    fi
  }

  # Run all components in parallel waves
  items=("${components[@]}") # lib/run_waves expects items[] array
  . "$(dirname "$0")"/lib/run_waves
fi

# Print pass/fail summary and exit with error if any component failed
print_results

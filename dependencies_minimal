#!/usr/bin/env bash
#
# Find the minimum dependencies needed for a repository's Selenium tests to pass.
# Uses a greedy algorithm: starts with all optional deps, removes one at a time.
# O(N) instead of O(2^N). Repeats until stable to catch order-dependent removals.
#
# Usage: ./dependencies_minimal extensions/Echo
#        VERBOSE=1 ./dependencies_minimal extensions/Echo
#
# See also: ./dependencies_minimal_thorough for exhaustive verification.
#
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#

# No set -euo pipefail: we want to continue after failures to test the next combination

. "$(dirname "$0")"/lib/minimal_setup "$@" # shared setup: read deps, classify, pre-clone

. "$(dirname "$0")"/lib/greedy # greedy algorithm: remove one dep at a time, repeat until stable

exit 0

#!/usr/bin/env bash
#
# Output required dependencies for an extension or skin from its extension.json or skin.json.
# These are the extensions/skins listed in the "requires" field that must always be present.
# Output format matches ./dependencies (bare names for extensions, "skins/Name" for skins).
#
# Usage: ./dependencies_required extensions/GrowthExperiments
#        ./dependencies_required skins/MinervaNeue
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Show usage if no argument provided
if [ $# -eq 0 ]; then # $# is the number of arguments
  echo "Usage: ./dependencies_required extensions/EXTENSION or ./dependencies_required skins/SKIN"
  exit 1
fi

component="$1" # e.g. "extensions/GrowthExperiments"

# Determine the JSON filename: extension.json for extensions, skin.json for skins
if [[ "$component" == skins/* ]]; then
  json_name="skin.json" # e.g. skin.json for skins/MinervaNeue
else
  json_name="extension.json" # e.g. extension.json for extensions/GrowthExperiments
fi

# Try to read the JSON file from src/ first (working copy), then fall back to the bare repo
# in ref/ via git show. The bare repo fallback is needed when called before ./install
# (e.g. from ./dependencies_minimal_greedy which reads required deps before installing the extension).
json_file="src/${component}/${json_name}" # e.g. src/extensions/GrowthExperiments/extension.json
bare_repo="ref/mediawiki/${component}.git" # e.g. ref/mediawiki/extensions/GrowthExperiments.git

if [ -f "$json_file" ]; then
  json_content=$(cat "$json_file") # read from working copy
elif [ -d "$bare_repo" ]; then
  json_content=$(git -C "$bare_repo" show "HEAD:${json_name}" 2>/dev/null) || exit 0 # read from bare repo; exit silently if file not found
else
  exit 0 # neither source available, no required deps to report
fi

# Parse the requires.extensions and requires.skins sections from the JSON content.
# See lib/parse_requires.awk for the parsing logic.
echo "$json_content" | awk -f "$(dirname "$0")"/lib/parse_requires.awk

#!/usr/bin/env bash
#
# Find the minimum dependencies needed for a repository's Selenium tests to pass.
# Uses a greedy algorithm: starts with all optional deps, removes one at a time.
# O(N) instead of O(2^N). Repeats until stable to catch order-dependent removals.
# Good general-purpose choice.
#
# Pick this when: speed matters more than guaranteed correctness (greedy can miss
# the true minimum). For a guaranteed minimum, use ./dependencies_minimal_bottom_up
# (fast when few deps are needed) or ./dependencies_minimal_thorough (fast when many).
#
# Fast for extensions/GrowthExperiments (17 deps, ~8 needed): ~17 tests regardless of
# how many are needed. Slower for extensions/Echo (4 deps, 0 needed): tests all 4 before
# concluding none are needed, while ./dependencies_minimal_bottom_up finds the answer in
# 1 test.
#
# Usage: ./dependencies_minimal_greedy extensions/Echo
#        VERBOSE=1 ./dependencies_minimal_greedy extensions/Echo
#
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#

# No set -euo pipefail: we want to continue after failures to test the next combination

. "$(dirname "$0")"/lib/minimal_setup "$@" # shared setup: read deps, classify, pre-clone

. "$(dirname "$0")"/lib/greedy # greedy algorithm: remove one dep at a time, repeat until stable

exit 0

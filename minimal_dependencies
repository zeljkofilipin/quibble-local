#!/usr/bin/env bash
#
# Find the minimum dependencies needed for a repository's Selenium tests to pass.
# Splits dependencies into required (from extension.json/skin.json) and optional
# (remaining deps from zuul). Required deps are always included. Only optional deps
# are varied, testing combinations from smallest (0 optional) to largest (all optional).
#
# Usage: ./minimal_dependencies extensions/Echo
#        VERBOSE=1 ./minimal_dependencies extensions/Echo
#        FAST=1 ./minimal_dependencies extensions/Echo
#        GREEDY=1 ./minimal_dependencies extensions/Echo
#        GREEDY=1 FAST=1 ./minimal_dependencies extensions/Echo
#        PARALLEL=$(./suggested_parallel) ./minimal_dependencies extensions/Echo
#        PARALLEL=4 FAST=1 ./minimal_dependencies extensions/Echo
#
# WARNING: Tests up to 2^N combinations (N = number of optional dependencies). Each
#          combination runs fresh_install + install + run_selenium_tests (~10 min).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
# FAST=1: Always runs fresh_install + install (with required deps) first, saves state, then restores.
# GREEDY=1: Starts with all deps, removes one at a time. O(N) instead of O(2^N).
#            Always runs sequentially (ignores PARALLEL).
# PARALLEL=N: Run N combinations in parallel (each in isolated src_worker_$i/ directory).
#             Only applies to exhaustive (non-greedy) mode.
#             Use ./suggested_parallel to determine N for your machine.
#

# No set -euo pipefail: we want to continue after failures to test the next combination

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking
fast="${FAST:-}" # FAST=1 saves fresh_install state and restores instead of re-running
greedy="${GREEDY:-}" # GREEDY=1 removes deps one at a time instead of testing all combinations
parallel="${PARALLEL:-1}" # PARALLEL=N runs N combinations in parallel (default 1 = sequential)
_first_run=1 # force fresh_install on first call (don't trust stale src_save/ from previous runs)


# Show usage if no argument provided
if [ $# -eq 0 ]; then # $# is the number of arguments
  echo "Usage: ./minimal_dependencies extensions/EXTENSION or ./minimal_dependencies skins/SKIN"
  exit 1
fi

component="$1" # e.g. "extensions/Echo"

# Read all dependencies (from zuul's dependencies.yaml)
all_deps=() # indexed array of all dependency names
while IFS= read -r dep; do
  [ -z "$dep" ] && continue # skip empty lines
  all_deps+=("$dep") # += appends to bash arrays
done < <("$(dirname "$0")"/dependencies "$component")

if [ ${#all_deps[@]} -eq 0 ]; then
  echo "No dependencies found for $component."
  exit 0
fi

# Read required dependencies (from extension.json/skin.json "requires" field)
required=() # indexed array of required dependency names
while IFS= read -r dep; do
  [ -z "$dep" ] && continue # skip empty lines
  required+=("$dep") # += appends to bash arrays
done < <("$(dirname "$0")"/required_dependencies "$component")

# Read optional dependencies (all deps minus required deps)
optional=() # indexed array of optional dependency names
while IFS= read -r dep; do
  [ -z "$dep" ] && continue # skip empty lines
  optional+=("$dep") # += appends to bash arrays
done < <("$(dirname "$0")"/optional_dependencies "$component")

n=${#optional[@]} # number of optional dependencies

# Build the required deps string (always included in QUIBBLE_DEPS)
required_str="" # space-separated list of required dep names
if [ ${#required[@]} -gt 0 ]; then # only iterate if array is non-empty (bash 3.2 safe)
  for dep in "${required[@]}"; do
    required_str="${required_str:+$required_str }$dep" # append with space separator
  done
fi

# Generate all combinations of optional deps (including empty set), ordered by size.
# See lib/combinations_with_empty.awk for the bitmask logic.
combos=() # array of space-separated optional dep combinations
if [ "$n" -gt 0 ]; then
  while IFS= read -r combo; do
    combos+=("$combo") # += appends to bash arrays
  done < <(printf '%s\n' "${optional[@]}" | awk -f "$(dirname "$0")"/lib/combinations_with_empty.awk)
else
  combos=("") # only the empty set (no optional deps to vary)
fi
total=${#combos[@]} # total number of combinations

# Print summary of all, required, and optional dependencies
. "$(dirname "$0")"/lib/print_dep_summary

# Helper: run fresh_install or restore (if FAST=1 and saved state exists)
# In fast mode, saves state after fresh_install + install (with required deps),
# so restores include MediaWiki + extension. Only optional deps vary per combination.
# First call always runs fresh_install (don't trust stale src_save/ from previous runs).
fresh_or_restore() {
  if [ -n "$fast" ] && [ -d src_save ] && [ -z "$_first_run" ]; then
    # Fast mode: restore from saved state instead of running fresh_install
    run_step "$component" ./restore
  else
    _first_run="" # clear after first run so subsequent calls can restore
    if run_step "$component" ./fresh_install; then
      # Save state after first successful fresh_install for fast mode
      if [ -n "$fast" ]; then
        # Install extension with required deps before saving, so restore includes
        # MediaWiki + extension. Only optional deps vary per combination.
        export QUIBBLE_DEPS="$required_str"
        if ! run_step "$component" ./install "$component"; then
          unset QUIBBLE_DEPS # clean up env var
          return 1
        fi
        unset QUIBBLE_DEPS # clean up env var
        run_step "$component" ./save
      fi
      return 0
    else
      return 1
    fi
  fi
}

# Pre-clone bare repos for all dependencies before testing.
# Prevents race conditions when parallel workers try to clone the same repo simultaneously.
# Also ensures network fetches don't slow down individual combination tests.
for dep_name in "${all_deps[@]}"; do
  if [[ "$dep_name" == skins/* ]]; then
    dep_repo="mediawiki/${dep_name}"   # e.g. "mediawiki/skins/MinervaNeue"
  else
    dep_repo="mediawiki/extensions/${dep_name}" # e.g. "mediawiki/extensions/Echo"
  fi
  dep_ref_dir="ref/${dep_repo}.git"    # e.g. "ref/mediawiki/extensions/Echo.git"
  if [ ! -d "$dep_ref_dir" ]; then
    mkdir -p "$(dirname "$dep_ref_dir")" # create parent directories
    if [ -n "$verbose" ]; then
      echo "Pre-cloning dependency: ${dep_name}" # print status message in verbose mode
      git clone --bare "https://gerrit.wikimedia.org/r/${dep_repo}" "$dep_ref_dir"
    else
      printf "pre-clone(%s) " "$dep_name" # print step label before dots
      run_with_dots "log/silent/pre-clone--${dep_name//\//-}.log" \
        git clone --bare "https://gerrit.wikimedia.org/r/${dep_repo}" "$dep_ref_dir"
      printf "\n" # newline after dots
    fi
  fi
done

if [ -n "$greedy" ]; then
  # --- Greedy algorithm: start with all deps, remove one at a time ---
  # O(N) instead of O(2^N). For each optional dep, try removing it.
  # If tests still pass without it, it's not needed.
  printf "\nGreedy mode: starting with all %d optional deps, removing one at a time.\n" "$n"

  # Start with all optional deps as "kept" (indices into the optional array)
  kept=() # indices of optional deps still included
  for i in $(seq 0 $((n - 1))); do
    kept+=("$i") # start with all optional deps
  done

  # First, verify tests pass with all dependencies
  printf "\n=== Baseline: all dependencies === %s\n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"
  if ! fresh_or_restore; then
    printf "SKIP (fresh_install/restore failed)\n"
    printf "\nCannot establish baseline.\n"
    exit 1
  fi

  # Build optional_combo from all optional deps for baseline test
  optional_combo=""
  if [ "$n" -gt 0 ]; then
    for dep in "${optional[@]}"; do
      optional_combo="${optional_combo:+$optional_combo }$dep" # space-separated
    done
  fi
  . "$(dirname "$0")"/lib/build_full_combo

  export QUIBBLE_DEPS="$full_combo"
  if ! run_step "$component" ./install "$component"; then
    unset QUIBBLE_DEPS
    printf "\nBaseline install failed with all dependencies.\n"
    exit 1
  fi
  unset QUIBBLE_DEPS

  if ! run_step "$component" ./run_selenium_tests "$component"; then
    printf "\nBaseline tests failed with all dependencies. Cannot determine minimum.\n"
    exit 1
  fi

  # Try removing each optional dep one at a time
  for i in $(seq 0 $((n - 1))); do
    dep="${optional[$i]}"
    printf "\n=== Try removing %s (%d/%d) === %s\n" "$dep" "$((i + 1))" "$n" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"

    # Build optional_combo without this dep (using kept indices, excluding i)
    new_kept=() # candidate kept list without current dep
    for k in "${kept[@]}"; do
      [ "$k" -eq "$i" ] && continue # skip the dep we're trying to remove
      new_kept+=("$k")
    done

    # Build optional_combo from new_kept indices
    optional_combo=""
    if [ ${#new_kept[@]} -gt 0 ]; then
      for k in "${new_kept[@]}"; do
        optional_combo="${optional_combo:+$optional_combo }${optional[k]}" # space-separated
      done
    fi
    . "$(dirname "$0")"/lib/build_full_combo

    if ! fresh_or_restore; then
      printf "SKIP (fresh_install/restore failed), keeping %s\n" "$dep"
      continue # keep this dep (can't test without it)
    fi

    export QUIBBLE_DEPS="$full_combo"
    if ! run_step "$component" ./install "$component"; then
      unset QUIBBLE_DEPS
      printf "Install failed without %s, keeping it\n" "$dep"
      continue # keep this dep
    fi
    unset QUIBBLE_DEPS

    if run_step "$component" ./run_selenium_tests "$component"; then
      printf "Tests passed without %s, removing it\n" "$dep"
      kept=("${new_kept[@]}") # permanently remove this dep
    else
      printf "Tests failed without %s, keeping it\n" "$dep"
      # kept stays unchanged (dep remains)
    fi
  done

  # Build final optional_combo from kept indices
  optional_combo=""
  if [ ${#kept[@]} -gt 0 ]; then
    for k in "${kept[@]}"; do
      optional_combo="${optional_combo:+$optional_combo }${optional[k]}" # space-separated
    done
  fi

  # Print results
  . "$(dirname "$0")"/lib/print_found
  exit 0
fi

# --- Exhaustive: test all combinations, smallest first ---
# Required deps are always included. Only optional deps are varied.
# When PARALLEL > 1, combinations are tested in waves of $parallel workers.

if [ "$parallel" -le 1 ]; then
  # --- Sequential mode (PARALLEL=1, default) ---
  # Uses run_step from lib/batch_setup for progress tracking.
  combo_num=0 # combination counter for progress display

  for optional_combo in "${combos[@]}"; do
    combo_num=$((combo_num + 1))

    # Build full combo: required deps + optional deps for this combination
    . "$(dirname "$0")"/lib/build_full_combo

    printf "\n=== Combination %d/%d: %s === %s\n" "$combo_num" "$total" "${full_combo:-(none)}" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"

    # Fresh core install for clean state (or restore from saved state in fast mode)
    if ! fresh_or_restore; then
      printf "SKIP (fresh_install/restore failed)\n"
      continue # try next combination
    fi

    # Install extension with this combination of deps
    # QUIBBLE_DEPS overrides ./dependencies in ./install (see install script)
    export QUIBBLE_DEPS="$full_combo"
    if ! run_step "$component" ./install "$component"; then
      unset QUIBBLE_DEPS # clean up env var
      printf "FAILED (install failed)\n"
      continue # try next combination
    fi
    unset QUIBBLE_DEPS # clean up env var (run_selenium_tests doesn't need it)

    # Run Selenium tests
    if run_step "$component" ./run_selenium_tests "$component"; then
      . "$(dirname "$0")"/lib/print_found # print the winning combination
      exit 0
    fi
  done

else
  # --- Parallel mode (PARALLEL > 1) ---
  # Process combinations in waves of $parallel workers.
  # Each worker runs in an isolated src_worker_$i/ directory.
  # FAST mode: fresh_install + install once, save, then each worker restores.
  # Normal mode: each worker runs fresh_install + install independently.
  printf "\nParallel mode: %d workers\n" "$parallel"

  if [ -n "$fast" ]; then
    # Fast mode: initial fresh_install + install + save (workers restore from src_save/)
    if ! fresh_or_restore; then
      printf "\nfresh_install/save failed. Cannot proceed.\n"
      exit 1
    fi

    # Ensure src_save/ exists for workers to restore from
    if [ ! -d src_save ]; then
      printf "\nError: src_save/ missing after fresh_install+save. Cannot proceed.\n"
      exit 1
    fi
  fi

  # Create result directory for workers to report pass/fail
  result_dir=$(mktemp -d) # temp dir for worker result files

  # Process combinations in waves
  wave_start=0 # index into combos array for start of current wave
  while [ "$wave_start" -lt "$total" ]; do
    wave_end=$((wave_start + parallel)) # exclusive end index
    if [ "$wave_end" -gt "$total" ]; then
      wave_end="$total" # last wave may be smaller
    fi
    wave_size=$((wave_end - wave_start))

    printf "\n--- Wave %d-%d of %d (%d workers) --- %s\n" \
      "$((wave_start + 1))" "$wave_end" "$total" "$wave_size" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"

    # Launch workers for this wave
    pids=() # array of background process IDs
    worker=0 # worker index (0-based, used for src_worker_$worker/)
    while [ "$worker" -lt "$wave_size" ]; do
      combo_idx=$((wave_start + worker))
      worker_optional="${combos[$combo_idx]}" # optional deps for this combination
      worker_src="src_worker_$((worker + 1))" # isolated src directory (1-based for readability)
      worker_log="log/silent/worker-$((worker + 1))" # per-worker log directory

      # Build full combo for this worker
      worker_full="" # full dep string for this worker
      if [ -n "$required_str" ] && [ -n "$worker_optional" ]; then
        worker_full="$required_str $worker_optional"
      elif [ -n "$required_str" ]; then
        worker_full="$required_str"
      else
        worker_full="$worker_optional"
      fi

      mkdir -p "$worker_src" "$worker_log" # create worker directories

      printf "  Worker %d: combo %d/%d: %s\n" "$((worker + 1))" "$((combo_idx + 1))" "$total" "${worker_full:-(none)}"

      # Launch worker in background subshell.
      # Fast mode: restore → install → run_selenium_tests in its own src directory.
      # Normal mode: fresh_install → install → run_selenium_tests in its own src directory.
      # QUIBBLE_SRC: isolated src directory for this worker
      # QUIBBLE_EXPOSE_PORT=0: skip port mapping (avoid port conflicts between workers)
      # QUIBBLE_BACKGROUND=1: skip -i/-t Docker flags (no stdin in background)
      # QUIBBLE_DEPS: dependency combination to test
      # Worker writes "pass" or "fail" to a result file.
      (
        export QUIBBLE_SRC="$worker_src"
        export QUIBBLE_EXPOSE_PORT=0
        export QUIBBLE_BACKGROUND=1
        export QUIBBLE_DEPS="$worker_full"

        # Redirect all output to worker log file
        exec > "$worker_log/combination-$((combo_idx + 1)).log" 2>&1

        # Set up core MediaWiki + extension in worker's src directory
        if [ -n "$fast" ]; then
          # Fast mode: restore from saved state (includes MediaWiki + extension + required deps)
          if ! ./restore; then
            echo "fail" > "$result_dir/worker_$combo_idx"
            exit 1
          fi
        else
          # Normal mode: fresh_install + install extension from scratch
          if ! ./fresh_install; then
            echo "fail" > "$result_dir/worker_$combo_idx"
            exit 1
          fi
        fi

        # Install extension with this combination of deps
        if ! ./install "$component"; then
          echo "fail" > "$result_dir/worker_$combo_idx"
          exit 1
        fi

        # Run Selenium tests
        if ./run_selenium_tests "$component"; then
          echo "pass" > "$result_dir/worker_$combo_idx"
        else
          echo "fail" > "$result_dir/worker_$combo_idx"
        fi
      ) &
      pids+=($!) # $! is the PID of the last background process

      worker=$((worker + 1))
    done

    # Wait for all workers in this wave to finish
    for pid in "${pids[@]}"; do
      wait "$pid" 2>/dev/null || true # wait for each worker (ignore exit code, check result files)
    done

    # Check results: find the smallest-index passing combination in this wave.
    # Combinations are already ordered by size, so the first pass is the answer.
    combo_idx="$wave_start"
    while [ "$combo_idx" -lt "$wave_end" ]; do
      result_file="$result_dir/worker_$combo_idx"
      if [ -f "$result_file" ] && [ "$(cat "$result_file")" = "pass" ]; then
        winning_optional="${combos[$combo_idx]}" # optional deps of the winning combo
        printf "\n  Combination %d/%d passed!\n" "$((combo_idx + 1))" "$total"
        rm -rf "$result_dir" # clean up temp dir
        optional_combo="$winning_optional" # set for lib/print_found
        . "$(dirname "$0")"/lib/print_found # print the winning combination
        exit 0
      fi
      combo_idx=$((combo_idx + 1))
    done

    printf "  All %d combinations in this wave failed.\n" "$wave_size"
    wave_start="$wave_end" # advance to next wave
  done

  # Clean up
  rm -rf "$result_dir"
fi

# If we get here, no combination passed (shouldn't happen if the extension's tests work at all)
printf "\nNo working combination found.\n"
exit 1

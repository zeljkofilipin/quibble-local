#!/usr/bin/env bash
#
# Find the minimum dependencies needed for a repository's Selenium tests to pass.
# Splits dependencies into required (from extension.json/skin.json) and optional
# (remaining deps from zuul). Required deps are always included. Only optional deps
# are varied, testing combinations from smallest (0 optional) to largest (all optional).
#
# Usage: ./minimal_dependencies extensions/Echo
#        VERBOSE=1 ./minimal_dependencies extensions/Echo
#
# WARNING: Tests up to 2^N combinations (N = number of optional dependencies). Each
#          combination runs fresh_install + install + run_selenium_tests (~10 min).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#

# No set -euo pipefail: we want to continue after failures to test the next combination

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking

# Show usage if no argument provided
if [ $# -eq 0 ]; then # $# is the number of arguments
  echo "Usage: ./minimal_dependencies extensions/EXTENSION or ./minimal_dependencies skins/SKIN"
  exit 1
fi

component="$1" # e.g. "extensions/Echo"

# Read all dependencies (from zuul's dependencies.yaml)
all_deps=() # indexed array of all dependency names
while IFS= read -r dep; do
  [ -z "$dep" ] && continue # skip empty lines
  all_deps+=("$dep") # += appends to bash arrays
done < <("$(dirname "$0")"/dependencies "$component")

if [ ${#all_deps[@]} -eq 0 ]; then
  echo "No dependencies found for $component."
  exit 0
fi

# Read required dependencies (from extension.json/skin.json "requires" field)
required=() # indexed array of required dependency names
while IFS= read -r dep; do
  [ -z "$dep" ] && continue # skip empty lines
  required+=("$dep") # += appends to bash arrays
done < <("$(dirname "$0")"/required_dependencies "$component")

# Read optional dependencies (all deps minus required deps)
optional=() # indexed array of optional dependency names
while IFS= read -r dep; do
  [ -z "$dep" ] && continue # skip empty lines
  optional+=("$dep") # += appends to bash arrays
done < <("$(dirname "$0")"/optional_dependencies "$component")

n=${#optional[@]} # number of optional dependencies

# Build the required deps string (always included in QUIBBLE_DEPS)
required_str="" # space-separated list of required dep names
if [ ${#required[@]} -gt 0 ]; then # only iterate if array is non-empty (bash 3.2 safe)
  for dep in "${required[@]}"; do
    required_str="${required_str:+$required_str }$dep" # append with space separator
  done
fi

# Generate all combinations of optional deps (including empty set), ordered by size.
# See lib/combinations_with_empty.awk for the bitmask logic.
combos=() # array of space-separated optional dep combinations
if [ "$n" -gt 0 ]; then
  while IFS= read -r combo; do
    combos+=("$combo") # += appends to bash arrays
  done < <(printf '%s\n' "${optional[@]}" | awk -f "$(dirname "$0")"/lib/combinations_with_empty.awk)
else
  combos=("") # only the empty set (no optional deps to vary)
fi
total=${#combos[@]} # total number of combinations

# Print summary of all, required, and optional dependencies
. "$(dirname "$0")"/lib/print_dep_summary

# --- Test all combinations, smallest first ---
# Uses run_step from lib/batch_setup for progress tracking.
# Required deps are always included. Only optional deps are varied.
combo_num=0 # combination counter for progress display

for optional_combo in "${combos[@]}"; do
  combo_num=$((combo_num + 1))

  # Build full combo: required deps + optional deps for this combination
  . "$(dirname "$0")"/lib/build_full_combo

  printf "\n=== Combination %d/%d: %s === %s\n" "$combo_num" "$total" "${full_combo:-(none)}" "$(date -u '+%Y-%m-%d %H:%M:%S UTC')"

  # Fresh core install for clean state
  if ! run_step "$component" ./fresh_install; then
    printf "SKIP (fresh_install failed)\n"
    continue # try next combination
  fi

  # Install extension with this combination of deps
  # QUIBBLE_DEPS overrides ./dependencies in ./install (see install script)
  export QUIBBLE_DEPS="$full_combo"
  if ! run_step "$component" ./install "$component"; then
    unset QUIBBLE_DEPS # clean up env var
    printf "FAILED (install failed)\n"
    continue # try next combination
  fi
  unset QUIBBLE_DEPS # clean up env var (run_selenium_tests doesn't need it)

  # Run Selenium tests
  if run_step "$component" ./run_selenium_tests "$component"; then
    # Tests passed — this is the smallest working combination
    printf "\n========================================\n"
    printf "= FOUND: minimum dependencies for %s\n" "$component"
    printf "========================================\n"
    if [ -z "$full_combo" ]; then
      printf "\nNo dependencies needed.\n"
    else
      printf "\nMinimum dependencies:\n"
      if [ ${#required[@]} -gt 0 ]; then
        printf "  Required (always needed):\n"
        for dep in "${required[@]}"; do
          printf "    %s\n" "$dep"
        done
      fi
      if [ -n "$optional_combo" ]; then
        printf "  Optional (minimum needed):\n"
        for dep in $optional_combo; do # intentional word splitting on space-separated combo
          printf "    %s\n" "$dep"
        done
      fi
    fi
    exit 0
  fi
done

# If we get here, no combination passed (shouldn't happen if the extension's tests work at all)
printf "\nNo working combination found.\n"
exit 1

#!/usr/bin/env bash
#
# Output the list of gated repositories (extensions and skins).
# Reads gatedextensions and gatedskins from parameter_functions.py.
# Clones integration/config into src/config if needed.
# Assumes ./prepare has been run first (needs ref/integration/config.git).
#
set -euo pipefail # exit on error, undefined vars, or pipe failures

# Clone integration/config working copy from bare repo if not already present
config_ref_dir="ref/integration/config.git" # bare repo cloned by ./prepare
config_src_dir="src/config"                 # working copy needed for parameter_functions.py
if [ ! -d "$config_src_dir" ]; then
  if [ ! -d "$config_ref_dir" ]; then
    echo "Error: $config_ref_dir not found. Run ./prepare first."
    exit 1
  fi
  git clone "$config_ref_dir" "$config_src_dir" # create working copy from bare repo
fi

# Path to the file containing gated extensions and skins lists
config_file="$config_src_dir/zuul/parameter_functions.py"

# Check that the config file exists
if [ ! -f "$config_file" ]; then
  echo "Error: $config_file not found."
  exit 1
fi

# Extract Python list entries from gatedextensions and gatedskins.
# Finds lines like '    'ExtensionName',' inside each list and strips quotes/whitespace.
# -v list=NAME: which Python list to extract from
# Looks for the list assignment, then prints each quoted entry until the closing bracket.
extract_list() {
  awk -v list="$1" '
    $0 ~ "^" list " = \\[" { found=1; next }  # start of the list
    found && /^\]/ { exit }                     # end of the list
    found && /'\''/ {                           # line with a quoted string
      gsub(/^[[:space:]]*'\''/, "")             # strip leading whitespace and opening quote
      gsub(/'\''.*/, "")                        # strip closing quote and everything after
      print                                     # print the extracted name
    }
  ' "$config_file"
}

# Print gated extensions prefixed with "extensions/"
extract_list "gatedextensions" | while IFS= read -r name; do
  echo "extensions/$name"
done

# Print gated skins prefixed with "skins/"
extract_list "gatedskins" | while IFS= read -r name; do
  echo "skins/$name"
done

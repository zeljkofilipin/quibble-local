#!/usr/bin/env bash
#
# Install each gated extension or skin into its own fresh MediaWiki, one at a time.
# For each component: fresh_install, then install. Reports per-step and total duration.
# Unlike install_all_gated (which stacks everything into one MediaWiki), this gives each
# component a clean MediaWiki so per-component install times are comparable.
# WARNING: Without arguments, this will take a very long time to run (50+ components).
# WARNING: This script inhibits sleep to prevent the machine from suspending.
#
# Usage: ./install_each_gated
#        ./install_each_gated extensions/Echo
#        VERBOSE=1 ./install_each_gated extensions/Echo
#        FAST=1 ./install_each_gated extensions/Echo
#        PARALLEL=1 ./install_each_gated extensions/Echo
#        PARALLEL=1 FAST=1 ./install_each_gated extensions/Echo
# FAST=1: Runs fresh_install once, saves state, then restores instead of re-running fresh_install.
# PARALLEL=N: Run N components in parallel (each in isolated src_worker_$i/ directory).
#             Use ./suggest_parallel to determine N for your machine.
#

# No set -euo pipefail: we want to continue after failures to collect all results

. "$(dirname "$0")"/lib/batch_setup # shared setup: verbose/silent mode, log dir, result tracking, duration
. "$(dirname "$0")"/lib/pluralize # provides pluralize() for grammatical worker counts ("1 worker"/"2 workers")
fast="${FAST:-}" # FAST=1 saves fresh_install state and restores instead of re-running
parallel="${PARALLEL:-0}" # PARALLEL=N runs N components in parallel, each in its own src dir; unset/0 = sequential (default)

# --- Build list of gated components ---
. "$(dirname "$0")"/lib/build_component_list # sets components[] from $1 or ./list_gated

if [ "$parallel" -lt 1 ]; then
  # --- Sequential mode ---
  # IFS= preserves whitespace in component names; -r prevents backslash interpretation.
  # <&3 reads from file descriptor 3 instead of stdin, because docker's -it flag needs stdin.
  # 3< <(...) is process substitution: connects array output to fd 3.
  while IFS= read -r component <&3; do
    print_header "$component"
    # Restore from saved state in fast mode, or run fresh_install
    if [ -n "$fast" ] && [ -d "${QUIBBLE_SAVE:-src_save}" ]; then
      core_ok=false; run_step "$component" ./restore && core_ok=true
    else
      core_ok=false; run_step "$component" ./fresh_install && core_ok=true
      # Save state after first successful fresh_install for fast mode
      if [ "$core_ok" = true ] && [ -n "$fast" ]; then
        run_step "$component" ./save
      fi
    fi
    if [ "$core_ok" = true ]; then # skip install if core setup fails
      run_step "$component" ./install "$component" # install extension/skin
    fi
    record_passed "$component"
    printf " %s\n" "$(utc_timestamp)" # print UTC timestamp after component
  done 3< <(printf '%s\n' "${components[@]}")

else
  # --- Parallel mode (lib/run_pool: a dynamic slot pool, refilled as each component finishes) ---
  # run_pool keeps $parallel slots busy and refills each the instant its component finishes; it
  # prints its own "Parallel mode: N slots" header. The hooks below isolate and report each item.

  if [ -n "$fast" ] && [ ! -d "${QUIBBLE_SAVE:-src_save}" ]; then
    # Fast mode needs a saved state. Run fresh_install + save first (workers restore from it).
    print_header "setup (fresh_install + save)"
    if run_step setup ./fresh_install; then
      run_step setup ./save
    else
      printf "\nfresh_install failed. Cannot proceed.\n"
      exit 1
    fi
    printf " %s\n" "$(utc_timestamp)"
  fi

  # Per-component log + result files, keyed by COMPONENT (not slot): run_pool reuses each slot id
  # as items finish, so a slot-keyed path would be clobbered before _pool_reap reads it. Each
  # component runs exactly once, so its name is a collision-free key. Rooted at $QUIBBLE_LOG_DIR so
  # a nested run (e.g. under generate_examples) can't collide with a sibling pool worker.
  _eachgated_log_dir="${QUIBBLE_LOG_DIR:-log/silent}/parallel"
  rm -rf "$_eachgated_log_dir"   # drop stale logs/results from a prior run
  mkdir -p "$_eachgated_log_dir"

  # lib/run_pool hook: worker body (background subshell). $1 = stable 1..parallel slot id, $2 =
  # component. Must NOT install its own EXIT trap — run_pool sets one to touch its sentinel.
  _run_pool_worker() {
    local component="$2"
    local log_file="$_eachgated_log_dir/${component//\//-}.log"
    local result_file="$_eachgated_log_dir/${component//\//-}.result"
    export ENVIRONMENT="$1"     # lib/setup derives QUIBBLE_SRC=src_$slot (isolated per slot)
    export QUIBBLE_BACKGROUND=1 # skip Docker -i/-t flags (no stdin in a background worker)
    exec > "$log_file" 2>&1     # capture this component's output to its per-component log
    # Set up core MediaWiki: restore from src_save (fast) or fresh_install, into this slot's src_$slot.
    if [ -n "$fast" ]; then
      if ! ./restore; then echo "fail" > "$result_file"; return 1; fi
    else
      if ! ./fresh_install; then echo "fail" > "$result_file"; return 1; fi
    fi
    # Install extension/skin
    if ./install "$component"; then
      echo "pass" > "$result_file"
    else
      echo "fail" > "$result_file"
    fi
  }

  # lib/run_pool hook: per-dispatch progress line (run_pool prints progress to stderr, so match it).
  _pool_worker_label() {
    printf "  Slot %d: %s (ENVIRONMENT=%d)\n" "$1" "$2" "$1" >&2
  }

  # lib/run_pool hook: per-completion. Runs in THIS shell (run_pool is sourced, not a subshell), so
  # it updates passed/failed directly, surfacing each result live. $1 = slot (unused), $2 = component.
  _pool_reap() {
    local component="$2" result=""
    local log_file="$_eachgated_log_dir/${component//\//-}.log"
    local result_file="$_eachgated_log_dir/${component//\//-}.result"
    [ -f "$result_file" ] && result=$(cat "$result_file")
    if [ "$result" = "pass" ]; then
      printf "  %s: ok\n" "$component"
      passed="$passed
  $component" # append component on a new indented line
    else
      printf "  %s: FAIL (see %s)\n" "$component" "$log_file"
      failed="$failed
  $component" # append component on a new indented line
    fi
  }

  # Run all components across $parallel reusable slots
  items=("${components[@]}")        # lib/run_pool processes this ambient items[] array
  . "$(dirname "$0")"/lib/run_pool
fi

# Print pass/fail summary and exit with error if any component failed
print_results
